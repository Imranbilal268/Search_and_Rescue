function addBlock(gx,gy,gz,bType,extra){
  if(bType!==undefined){var prev=selectedBlock;selectedBlock=bType;}
  const key=K(gx,gy,gz);if(placed.has(key)){if(bType!==undefined)selectedBlock=prev;return;}
  const b=BLOCKS[selectedBlock];
  const isStair=selectedBlock===Ty.STAIRWL;
  const stairRise=(extra&&extra.rise)||1.0;
  const stairDir=(extra&&extra.dir)||0; // 0=Z, 1=X
  const dims=isStair?[1,stairRise,1]:getDims(selectedBlock,gx,gy,gz);
  const geo=isStair?createStairGeo(stairRise):new THREE.BoxGeometry(dims[0],dims[1],dims[2]);
  let mat;
  if(b.isFire)mat=new THREE.MeshStandardMaterial({color:0xff4400,emissive:0xff3300,emissiveIntensity:1.2,transparent:true,opacity:.5,roughness:.3});
  else{
    let rough=.7,metal=.05;
    if(b.name==='METAL'||b.name==='RAILNG'){rough=.3;metal=.8;}
    else if(b.name==='CONCRT'||b.name==='THRSHD'){rough=.95;metal=0;}
    else if(b.name==='TILE'){rough=.2;metal=.05;}
    else if(b.name==='CARPET'||b.name==='FABRIC'){rough=1;metal=0;}
    else if(b.name==='DRYWL'||b.name==='PLASTR'){rough=.9;metal=0;}
    else if(b.name==='DOORPN'){rough=.6;metal=0;}
    else if(b.name==='DOORFR'){rough=.7;metal=0;}
    else if(b.name==='STAIRW'){rough=.6;metal=0;}
    mat=new THREE.MeshStandardMaterial({color:b.color,emissive:b.emissive||0,emissiveIntensity:b.emissiveI||0,roughness:rough,metalness:metal,transparent:!!b.opacity,opacity:b.opacity||1});
  }
  const mesh=new THREE.Mesh(geo,mat);
  mesh.position.set(gx,isStair?gy:gy+dims[1]/2,gz);
  if(isStair&&stairDir===1) mesh.rotation.y=-Math.PI/2; // rotate for X-run
  mesh.castShadow=true;mesh.receiveShadow=true;scene.add(mesh);
  const entry={mesh,type:selectedBlock,hp:b.maxHP,maxHP:b.maxHP,onFire:false,fireTick:0,integrity:1,gx,gy,gz,origColor:b.color,dims,stairRise,stairDir};
  placed.set(key,entry);applyView(entry);
  if(bType!==undefined)selectedBlock=prev;
  return entry;
}

function createBlock(gx,gy,gz){
  const entry=addBlock(gx,gy,gz);
