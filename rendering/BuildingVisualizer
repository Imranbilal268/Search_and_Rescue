  // --- ROOF (flat metal) ---
  const ry=FL*3;
  floorRect(o, ox,oz, ox+W-1,oz+D-1, ry, Ty.METAL);
  // Roof parapet
  wallRect(o, ox,oz, ox+W-1,oz+D-1, ry+1, Ty.STONE);
