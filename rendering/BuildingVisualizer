  const blocks=dedup(raw);const prev=selectedBlock;
  for(const b of blocks)addBlock(b[0],b[1],b[2],b[3],b[4]);
  selectedBlock=prev;for(const[k]of placed)rebuildGeo(k);
  const bldg=json.building||json;
  if(bldg.room_labels){
