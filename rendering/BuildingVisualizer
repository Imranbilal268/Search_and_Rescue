function dedup(arr){const m=new Map();for(const b of arr)m.set(K(b[0],b[1],b[2]),b);return[...m.values()];}

// Helper: fill rect of walls (perimeter only) at height y
function wallRect(o,x1,z1,x2,z2,y,t){
  for(let x=x1;x<=x2;x++){o.push([x,y,z1,t]);o.push([x,y,z2,t]);}
  for(let z=z1+1;z<z2;z++){o.push([x1,y,z,t]);o.push([x2,y,z,t]);}
}
// Helper: fill solid floor
function floorRect(o,x1,z1,x2,z2,y,t){
  for(let x=x1;x<=x2;x++)for(let z=z1;z<=z2;z++)o.push([x,y,z,t]);
}
// Helper: wall line along X
function wallX(o,x1,x2,y,z,t){for(let x=x1;x<=x2;x++)o.push([x,y,z,t]);}
// Helper: wall line along Z
function wallZ(o,z1,z2,y,x,t){for(let z=z1;z<=z2;z++)o.push([x,y,z,t]);}

function genApartment(ox,oz){
  const o=[];
  // 10 wide x 8 deep, 5 floors, 3 blocks per floor (floor + 2 wall)
  const W=10, D=8, FL=5;
  // Structural metal columns at corners + midpoints (run full height)
  const colPos=[[0,0],[0,D-1],[W-1,0],[W-1,D-1],[0,4],[W-1,4],[5,0],[5,D-1]];
  for(const[cx,cz]of colPos) for(let y=0;y<FL*3+1;y++) o.push([ox+cx,y,oz+cz,Ty.METAL]);

  for(let f=0;f<FL;f++){
    const by=f*3;
    // Floor slab (stone ground floor, wood upper)
    floorRect(o, ox,oz, ox+W-1,oz+D-1, by, f===0?Ty.STONE:Ty.WOOD);
    // Exterior walls (brick, 2 high)
    for(let h=1;h<=2;h++){
      wallRect(o, ox,oz, ox+W-1,oz+D-1, by+h, Ty.BRICK);
    }
    // --- WINDOWS: pairs on front/back at h=2, singles on sides ---
    // Front (z=oz) windows
    for(let x=1;x<W-1;x++){
      if(x===4||x===5) continue; // entrance bay or stairwell
      if(x%2===0) o.push([ox+x,by+2,oz,Ty.GLASS]);
    }
    // Back (z=oz+D-1) windows
    for(let x=1;x<W-1;x++){
      if(x===4||x===5) continue;
      if(x%2===1) o.push([ox+x,by+2,oz+D-1,Ty.GLASS]);
    }
    // Side windows
    for(let z=1;z<D-1;z++){
      if(z%2===1){o.push([ox,by+2,oz+z,Ty.GLASS]);o.push([ox+W-1,by+2,oz+z,Ty.GLASS]);}
    }

    // --- STAIRWELL (x=4..5, z=oz+D-3..oz+D-1) enclosed in brick ---
    // Stairwell walls (interior side only, exterior already done)
    for(let h=1;h<=2;h++){
      wallZ(o, oz+D-3, oz+D-2, by+h, ox+3, Ty.BRICK); // west stairwell wall
      wallX(o, ox+4, ox+5, by+h, oz+D-3, Ty.BRICK);    // south stairwell wall
    }
    // Stairwell door
    o.push([ox+4,by+1,oz+D-3,Ty.WOOD]); // door opening
    // Stairs (wood steps)
    if(f<FL-1){
      o.push([ox+4,by+1,oz+D-2,Ty.WOOD]);
      o.push([ox+5,by+2,oz+D-2,Ty.WOOD]);
      o.push([ox+4,by+1,oz+D-1,Ty.WOOD]); // landing (override back wall)
    }

    // --- CENTRAL HALLWAY (z=oz+4, running east-west) ---
    for(let h=1;h<=2;h++){
      wallX(o, ox+1, ox+W-2, by+h, oz+4, Ty.WOOD);
    }
    // Hallway doors into apartments (gaps)
    for(const dx of [2,6,8]){
      o.push([ox+dx,by+1,oz+4,Ty.WOOD]); // door (override wall)
    }

    // --- APARTMENT DIVIDER WALLS (split into 3 units per side) ---
    // Unit dividers at x=3 and x=7
    for(const dx of [3,7]){
      for(let h=1;h<=2;h++){
        wallZ(o, oz+1, oz+3, by+h, ox+dx, Ty.WOOD); // south side units
        wallZ(o, oz+5, oz+D-2, by+h, ox+dx, Ty.BRICK); // north side units
      }
    }
    // Kitchen/bathroom partition inside each unit (short wood wall)
    for(const dx of [1,5]){
      o.push([ox+dx,by+1,oz+2,Ty.WOOD]);
      o.push([ox+dx,by+1,oz+6,Ty.WOOD]);
    }

    // --- FRONT ENTRANCE (ground floor only) ---
    if(f===0){
      // Double door at center front
      o.push([ox+4,by+1,oz,Ty.GLASS]); o.push([ox+5,by+1,oz,Ty.GLASS]); // glass doors
      o.push([ox+4,by+2,oz,Ty.GLASS]); o.push([ox+5,by+2,oz,Ty.GLASS]); // transom
      // Lobby: open area, no hallway wall near entrance
      // Remove hallway wall in lobby area (override with nothing — push glass decorative)
      o.push([ox+4,by+1,oz+4,Ty.GLASS]); o.push([ox+5,by+1,oz+4,Ty.GLASS]);
      // Lobby light
      o.push([ox+4,by+2,oz+2,Ty.GLOW]); o.push([ox+5,by+2,oz+2,Ty.GLOW]);
    }

    // --- BALCONIES (floors 2+, front face, stone slab cantilevers) ---
    if(f>=1){
      for(const dx of [1,2,6,7,8]){
        o.push([ox+dx,by,oz-1,Ty.STONE]); // balcony slab
      }
      // Balcony railing (metal)
      for(const dx of [1,2,6,7,8]){
        o.push([ox+dx,by+1,oz-1,Ty.METAL]);
      }
    }

    // --- HALLWAY LIGHTS ---
    o.push([ox+3,by+2,oz+4,Ty.GLOW]);
    o.push([ox+7,by+2,oz+4,Ty.GLOW]);
  }

  // --- ROOF ---
  const ry=FL*3;
  floorRect(o, ox,oz, ox+W-1,oz+D-1, ry, Ty.STONE);
  // Parapet (stone rim)
  wallRect(o, ox,oz, ox+W-1,oz+D-1, ry+1, Ty.STONE);
  // HVAC units on roof
