function updFireVis(dt){const t=performance.now()*.001;let fcx=0,fcy=0,fcz=0,fc=0;for(const[,entry]of placed){const b=BLOCKS[entry.type];if(entry.onFire){const rate=b.isFire?10:(b.flamm===2?6:3);for(let i=0;i<Math.ceil(rate*dt*12);i++)spawnP(entry.gx,entry.gy,entry.gz,'fire');if(b.flamm===2&&entry.integrity<.5)for(let i=0;i<Math.ceil(3*dt*8);i++)spawnP(entry.gx,entry.gy+.5,entry.gz,'smoke');fcx+=entry.gx;fcy+=entry.gy;fcz+=entry.gz;fc++;if(viewMode==='standard'){if(b.isFire){entry.mesh.material.emissiveIntensity=1+Math.sin(t*10)*.3;entry.mesh.material.opacity=.3+Math.sin(t*7)*.15;const s=.8+Math.sin(t*5)*.1;entry.mesh.scale.set(s,.7+Math.sin(t*6)*.25,s);}else{const dmg=1-entry.integrity;const r=((entry.origColor>>16)&0xff)/255,g=((entry.origColor>>8)&0xff)/255,bl=(entry.origColor&0xff)/255;entry.mesh.material.color.setRGB(r*(1-dmg*.7)+dmg*.12,g*(1-dmg*.85),bl*(1-dmg*.9));entry.mesh.material.emissive.setRGB(.6+Math.sin(t*8+entry.gx)*.2,.15+Math.sin(t*6+entry.gz)*.1,0);entry.mesh.material.emissiveIntensity=.35+dmg*.45;entry.mesh.scale.setScalar(.65+.35*entry.integrity);}}}else if(viewMode==='standard'){if(entry.integrity<1){const dmg=1-entry.integrity;const r=((entry.origColor>>16)&0xff)/255,g=((entry.origColor>>8)&0xff)/255,bl=(entry.origColor&0xff)/255;entry.mesh.material.color.setRGB(r*(1-dmg*.5)+dmg*.06,g*(1-dmg*.6),bl*(1-dmg*.5));}else if(b.emissiveI&&b.emissiveI>.3&&!b.isFire){entry.mesh.material.emissiveIntensity=b.emissiveI*(.8+.2*Math.sin(t*3+entry.gx));}}}if(fc>0){fireL.position.set(fcx/fc,fcy/fc+2,fcz/fc);fireL.intensity=Math.min(fc*.6,10)*(.8+Math.sin(t*12)*.2);}else fireL.intensity*=.9;}
