  // Skylight over gym area
  for(let x=6;x<=9;x++) o.push([ox+x,ry,oz+2,Ty.GLASS]);
  return o;
}

function genGasStation(ox,oz){
  const o=[];
  // Overall lot: 14 wide x 11 deep
  const LW=14, LD=11;
  // Concrete pad
  floorRect(o, ox,oz, ox+LW-1,oz+LD-1, 0, Ty.STONE);

  // === CONVENIENCE STORE (right side: x=8..13, z=3..9) ===
  const sx=ox+8, sz=oz+3, sw=6, sd=7;
  // Walls (brick, 3 high for taller single story)
  for(let h=1;h<=3;h++) wallRect(o, sx,sz, sx+sw-1,sz+sd-1, h, Ty.BRICK);

  // Front windows (z=sz, full glass wall — override brick)
  for(let x=1;x<sw-1;x++){
    o.push([sx+x,1,sz,Ty.GLASS]);
    o.push([sx+x,2,sz,Ty.GLASS]);
    o.push([sx+x,3,sz,Ty.GLASS]); // full height glass
  }
  // Glass door (center front)
  o.push([sx+2,1,sz,Ty.WOOD]);o.push([sx+3,1,sz,Ty.WOOD]);
  // Side windows
  for(let z=sz+2;z<=sz+sd-3;z+=2){
    o.push([sx,2,z,Ty.GLASS]);
    o.push([sx+sw-1,2,z,Ty.GLASS]);
  }
  // Roof (wood joists + stone slab)
  floorRect(o, sx,sz, sx+sw-1,sz+sd-1, 4, Ty.WOOD);
  // Flat roof cap
  floorRect(o, sx,sz, sx+sw-1,sz+sd-1, 5, Ty.STONE);

  // Interior: checkout counter (near door)
  wallX(o, sx+1,sx+2, 1, sz+1, Ty.WOOD);
  o.push([sx+1,2,sz+1,Ty.GLOW]); // register light

  // Aisle shelving (wood)
  for(let z=sz+3;z<=sz+5;z++){
    o.push([sx+1,1,z,Ty.WOOD]); o.push([sx+1,2,z,Ty.WOOD]);
    o.push([sx+3,1,z,Ty.WOOD]); o.push([sx+3,2,z,Ty.WOOD]);
  }
  // Cooler wall (back, glass front)
  for(let x=sx+1;x<=sx+4;x++){
    o.push([x,1,sz+sd-2,Ty.METAL]); // cooler back
    o.push([x,2,sz+sd-2,Ty.GLASS]); // glass doors
  }
  // Interior lights
  for(let x=sx+1;x<sx+sw-1;x+=2) o.push([sx+x>sx+sw-1?sx+sw-2:x,4,sz+3,Ty.GLOW]);
  o.push([sx+2,4,sz+3,Ty.GLOW]);o.push([sx+4,4,sz+5,Ty.GLOW]);

  // Back storage room (brick partition inside)
  for(let h=1;h<=3;h++){
    wallX(o, sx+1,sx+sw-2, h, sz+sd-3, Ty.BRICK);
  }
  o.push([sx+2,1,sz+sd-3,Ty.WOOD]); // storage door

  // === CANOPY (left side: x=ox..ox+6, z=oz+2..oz+9) ===
  // 6 metal pillars
  const pils=[[ox+1,oz+2],[ox+1,oz+9],[ox+5,oz+2],[ox+5,oz+9],[ox+1,oz+5],[ox+5,oz+5]];
  for(const[px,pz]of pils) for(let y=1;y<=5;y++) o.push([px,y,pz,Ty.METAL]);
  // Canopy roof (metal, large)
  floorRect(o, ox,oz+1, ox+6,oz+10, 6, Ty.METAL);
  // Canopy edge trim
  wallRect(o, ox,oz+1, ox+6,oz+10, 6, Ty.STONE);
  // Underside lighting
  for(let x=ox+2;x<=ox+4;x++){
    o.push([x,5,oz+3,Ty.GLOW]);
    o.push([x,5,oz+5,Ty.GLOW]);
    o.push([x,5,oz+7,Ty.GLOW]);
    o.push([x,5,oz+9,Ty.GLOW]);
  }

  // === FUEL PUMP ISLANDS (concrete raised pads + pumps) ===
  // Island 1: z=oz+3..oz+4
  for(let x=ox+2;x<=ox+4;x++){
    o.push([x,1,oz+3,Ty.STONE]); // raised pad
    o.push([x,1,oz+4,Ty.STONE]);
  }
  o.push([ox+2,2,oz+3,Ty.METAL]);o.push([ox+2,3,oz+3,Ty.GLOW]); // pump 1
  o.push([ox+4,2,oz+3,Ty.METAL]);o.push([ox+4,3,oz+3,Ty.GLOW]); // pump 2
  o.push([ox+2,2,oz+4,Ty.METAL]);o.push([ox+2,3,oz+4,Ty.GLOW]); // pump 3
  o.push([ox+4,2,oz+4,Ty.METAL]);o.push([ox+4,3,oz+4,Ty.GLOW]); // pump 4

  // Island 2: z=oz+7..oz+8
  for(let x=ox+2;x<=ox+4;x++){
    o.push([x,1,oz+7,Ty.STONE]);
    o.push([x,1,oz+8,Ty.STONE]);
  }
  o.push([ox+2,2,oz+7,Ty.METAL]);o.push([ox+2,3,oz+7,Ty.GLOW]);
  o.push([ox+4,2,oz+7,Ty.METAL]);o.push([ox+4,3,oz+7,Ty.GLOW]);
  o.push([ox+2,2,oz+8,Ty.METAL]);o.push([ox+2,3,oz+8,Ty.GLOW]);
  o.push([ox+4,2,oz+8,Ty.METAL]);o.push([ox+4,3,oz+8,Ty.GLOW]);

  // === UNDERGROUND FUEL TANKS ===
  o.push([ox+3,0,oz+3,Ty.LAVA]);o.push([ox+3,0,oz+4,Ty.LAVA]);
  o.push([ox+3,0,oz+7,Ty.LAVA]);o.push([ox+3,0,oz+8,Ty.LAVA]);

  // === SIGNAGE POLE (tall metal tower) ===
  for(let y=1;y<=8;y++) o.push([ox,y,oz,Ty.METAL]);
  o.push([ox,8,oz+1,Ty.METAL]); // sign arm
  o.push([ox+1,8,oz,Ty.METAL]);
  o.push([ox,9,oz,Ty.GLOW]); // illuminated sign top

  // === DUMPSTER ENCLOSURE (back-right corner) ===
  // Brick walls enclosing trash area
  for(let h=1;h<=2;h++){
    wallX(o, sx+sw, sx+sw+1, h, sz+sd-1, Ty.BRICK);
    wallZ(o, sz+sd-2, sz+sd-1, h, sx+sw+1, Ty.BRICK);
  }
  o.push([sx+sw,1,sz+sd-2,Ty.METAL]); // dumpster body
  o.push([sx+sw+1,1,sz+sd-2,Ty.METAL]);

  // === ICE MACHINE (outside store front) ===
  o.push([sx-1,1,sz,Ty.METAL]);
  o.push([sx-1,2,sz,Ty.METAL]);

  // === AIR/WATER STATION (far left) ===
  o.push([ox,1,oz+LD-1,Ty.METAL]);
  o.push([ox,2,oz+LD-1,Ty.GLOW]);

  return o;
}

function spawnPreset(type){
  let raw;
  if(type==='apartment')raw=genApartment(-5,-4);
  else if(type==='school')raw=genSchool(-8,-5);
  else if(type==='gasstation')raw=genGasStation(-7,-5);
  else if(type==='stairdemo'){spawnStairDemo();return;}
  else if(type==='house'){spawnHouse();return;}
  if(!raw)return;
  const blocks=dedup(raw);
  for(const b of blocks)addBlock(b[0],b[1],b[2],b[3],b[4]);
  for(const[k]of placed)rebuildGeo(k);
  updateStats();
  panX=0;panY=0;
  camFocus();
  if(dimMode==='2d'){resize2d();draw2d();}
}
