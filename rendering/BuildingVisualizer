function genSchool(ox,oz){
  const o=[];
  // 16 wide x 10 deep, 2 floors
  const W=16, D=10, FL=2;

  // Structural columns (metal)
  for(const[cx,cz]of[[0,0],[0,D-1],[W-1,0],[W-1,D-1],[8,0],[8,D-1],[0,5],[W-1,5],[8,5]])
    for(let y=0;y<FL*3+1;y++) o.push([ox+cx,y,oz+cz,Ty.METAL]);

  for(let f=0;f<FL;f++){
    const by=f*3;
    // Floor slab
    floorRect(o, ox,oz, ox+W-1,oz+D-1, by, f===0?Ty.STONE:Ty.WOOD);
    // Exterior walls
    for(let h=1;h<=2;h++) wallRect(o, ox,oz, ox+W-1,oz+D-1, by+h, Ty.BRICK);

    // --- FRONT FACADE: large glass window bands ---
    for(let x=1;x<W-1;x++){
      if(x===7||x===8) continue; // main entrance
      o.push([ox+x,by+1,oz,Ty.GLASS]);
      o.push([ox+x,by+2,oz,Ty.GLASS]);
    }
    // Side windows (high strip)
    for(let z=1;z<D-1;z++){
      if(z%2===0){o.push([ox,by+2,oz+z,Ty.GLASS]);o.push([ox+W-1,by+2,oz+z,Ty.GLASS]);}
    }
    // Back windows
    for(let x=1;x<W-1;x++){
      if(x%2===0) o.push([ox+x,by+2,oz+D-1,Ty.GLASS]);
    }

    // --- MAIN ENTRANCE (double glass doors + vestibule) ---
    if(f===0){
      o.push([ox+7,by+1,oz,Ty.GLASS]); o.push([ox+8,by+1,oz,Ty.GLASS]); // doors
      o.push([ox+7,by+2,oz,Ty.GLASS]); o.push([ox+8,by+2,oz,Ty.GLASS]); // above
      // Vestibule walls
      for(let h=1;h<=2;h++){o.push([ox+6,by+h,oz+1,Ty.GLASS]);o.push([ox+9,by+h,oz+1,Ty.GLASS]);}
    }

    // --- CENTRAL HALLWAY running east-west at z=oz+5 ---
    for(let h=1;h<=2;h++){
      // North hallway wall
      wallX(o, ox+1, ox+W-2, by+h, oz+5, Ty.BRICK);
      // South hallway wall (only on classroom side, not near entrance)
      wallX(o, ox+1, ox+5, by+h, oz+3, Ty.BRICK);
      wallX(o, ox+10, ox+W-2, by+h, oz+3, Ty.BRICK);
    }
    // Hallway doors
    for(const dx of [3,6,11,14]){
      o.push([ox+dx,by+1,oz+5,Ty.WOOD]); // into north classrooms
      if(dx<=5||dx>=10) o.push([ox+dx,by+1,oz+3,Ty.WOOD]); // into south classrooms
    }
    // Hallway lights
    for(let x=2;x<W-1;x+=3) o.push([ox+x,by+2,oz+4,Ty.GLOW]);

    // --- CLASSROOMS (divided by wood partition walls) ---
    // North side classrooms: between hallway and back wall
    for(const dx of [4,8,12]){
      for(let h=1;h<=2;h++) wallZ(o, oz+6, oz+D-2, by+h, ox+dx, Ty.WOOD);
      o.push([ox+dx,by+1,oz+7,Ty.WOOD]); // door gap -> already wood, acts as door
    }

    // South side rooms (classrooms + offices)
    // Left block: rooms at x=0..5
    for(let h=1;h<=2;h++) wallZ(o, oz+1, oz+2, by+h, ox+5, Ty.WOOD);
    // Right block: rooms at x=10..15
    for(let h=1;h<=2;h++) wallZ(o, oz+1, oz+2, by+h, ox+10, Ty.WOOD);
    for(let h=1;h<=2;h++) wallZ(o, oz+1, oz+2, by+h, ox+13, Ty.WOOD);

    // --- LARGE ROOM: gym/cafeteria on south side center (x=6..9, z=1..3) ---
    // This area is open (between entrance vestibule and hallway walls)
    // Admin office: south-west corner (x=1..4, z=1..2)
    for(let h=1;h<=2;h++){
      wallX(o, ox+1, ox+4, by+h, oz+2, Ty.WOOD);
      o.push([ox+4,by+h,oz+1,Ty.WOOD]);
    }
    o.push([ox+3,by+1,oz+2,Ty.WOOD]); // office door

    // Classroom furniture (wood desks — sparse representation)
    if(f===0){
      // Desks in north classrooms
      for(const[dx,dz]of[[2,7],[2,8],[6,7],[6,8],[10,7],[10,8],[14,7],[14,8]]){
        o.push([ox+dx,by+1,oz+dz,Ty.WOOD]);
