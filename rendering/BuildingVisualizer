<script>
const Ty={STONE:0,BRICK:1,WOOD:2,GLASS:3,GRASS:4,SAND:5,METAL:6,GLOW:7,WATER:8,LAVA:9,FIRE:10,CONCRETE:11,DRYWALL:12,CARPET:13,TILE:14,FABRIC:15,PLASTER:16,DOORPNL:17,DOORFRM:18,STAIRWL:19,RAILING:20,THRESHD:21};
const BLOCKS=[
  {name:'STONE',   color:0x8a9bae,emissive:0x000000,flamm:1,maxHP:100},
  {name:'BRICK',   color:0xc75b3a,emissive:0x100000,flamm:1,maxHP:120},
