// ===== STATS & LOOP =====
function updateStats(){
  document.getElementById('s-blocks').textContent=placed.size;
  document.getElementById('s-layer').textContent=currentLayer;
  document.getElementById('s-layer-m').textContent=(currentLayer*SCALE).toFixed(2)+'m';
  document.getElementById('s-fire').textContent=fires.size;
  let d=0;for(const e of placed.values())if(e.integrity<1)d++;
  document.getElementById('s-dmg').textContent=d;

  // Compute physical dimensions
  let minX=Infinity,maxX=-Infinity,minY=Infinity,maxY=-Infinity,minZ=Infinity,maxZ=-Infinity;
  const layerCounts=new Map(); // y -> count
  for(const[,e]of placed){
    if(e.gx<minX)minX=e.gx;if(e.gx>maxX)maxX=e.gx;
    if(e.gy<minY)minY=e.gy;if(e.gy>maxY)maxY=e.gy;
    if(e.gz<minZ)minZ=e.gz;if(e.gz>maxZ)maxZ=e.gz;
    layerCounts.set(e.gy,(layerCounts.get(e.gy)||0)+1);
  }
  if(placed.size>0){
    const fw=((maxX-minX+1)*SCALE).toFixed(2);
    const fd=((maxZ-minZ+1)*SCALE).toFixed(2);
    const fh=((maxY-minY+1)*SCALE).toFixed(2);
    document.getElementById('s-footprint').textContent=fw+'m × '+fd+'m';
    document.getElementById('s-height').textContent=fh+'m ('+(maxY-minY+1)+' layers)';
  }else{
    document.getElementById('s-footprint').textContent='—';
    document.getElementById('s-height').textContent='—';
  }
  document.getElementById('s-grid-m').textContent=(GRID*SCALE).toFixed(1)+'m × '+(GRID*SCALE).toFixed(1)+'m';

  // Build layer list + nav + floors
  const ll=document.getElementById('layerList');
  ll.innerHTML='';
  const sortedLayers=[...layerCounts.entries()].sort((a,b)=>b[0]-a[0]);
  const maxCt=sortedLayers.length?Math.max(...sortedLayers.map(l=>l[1])):1;

  // Update nav display
  document.getElementById('lyNavY').textContent='Y'+currentLayer;
  document.getElementById('lyNavM').textContent=(currentLayer*SCALE).toFixed(2)+'m';
  const slider=document.getElementById('lySlider');
  if(placed.size>0){
    slider.min=Math.max(0,minY);slider.max=maxY+2;
  }
  slider.value=currentLayer;

  // Floor buttons (every WALL_H+1 = 4 layers = 1 floor)
  const FLOOR_H=4;
  const floorsDiv=document.getElementById('lyFloors');
  floorsDiv.innerHTML='';
  if(placed.size>0){
    const loF=Math.floor(minY/FLOOR_H),hiF=Math.floor(maxY/FLOOR_H);
    for(let f=0;f<=hiF-loF;f++){
      const fy=loF+f;
      const baseY=fy*FLOOR_H;
      const isActive=currentLayer>=baseY&&currentLayer<baseY+FLOOR_H;
      const btn=document.createElement('button');
      btn.className='ly-floor-btn'+(isActive?' active':'');
      btn.textContent='F'+(f+1)+' (Y'+baseY+')';
      btn.onclick=()=>goToLayer(baseY);
      floorsDiv.appendChild(btn);
    }
  }

  // Layer rows
  for(const[ly,ct]of sortedLayers){
    const row=document.createElement('div');
    row.className='layer-row'+(ly===currentLayer?' active':'');
    const hM=(ly*SCALE).toFixed(2);
    const pct=Math.round(ct/maxCt*100);
    row.innerHTML=
      '<div class="ly-info" onclick="goToLayer('+ly+')">'+
        '<span class="ly-y">Y'+ly+'</span>'+
        '<span class="ly-m">'+hM+'m</span>'+
        '<div class="ly-bar-wrap"><div class="ly-bar" style="width:'+pct+'%"></div></div>'+
        '<span class="ly-ct">'+ct+'</span>'+
      '</div>'+
      '<button class="ly-del" onclick="event.stopPropagation();deleteLayer('+ly+')" title="Delete layer Y'+ly+'">×</button>';
    ll.appendChild(row);
  }
  if(sortedLayers.length===0){
    const em=document.createElement('div');
    em.style.cssText='font-family:JetBrains Mono,monospace;font-size:8px;color:rgba(255,255,255,.15);text-align:center;padding:12px 0';
    em.textContent='No blocks placed';
    ll.appendChild(em);
  }
  // Scroll active layer into view
  const activeRow=ll.querySelector('.layer-row.active');
  if(activeRow) activeRow.scrollIntoView({block:'nearest',behavior:'smooth'});
}

// Layer controls
function layerStep(dir){
  currentLayer=Math.max(0,Math.min(60,currentLayer+dir));
  buildGrid();updateStats();
  if(dimMode==='2d')draw2d();
  applyVisibility();
}

function goToLayer(y){
  currentLayer=y;
  buildGrid();updateStats();
  if(dimMode==='2d')draw2d();
  applyVisibility();
}

let isolateMode='none'; // 'none','solo','above'
function toggleIsolate(){
  isolateMode=isolateMode==='solo'?'none':'solo';
  document.getElementById('lyIsoBtn').classList.toggle('active',isolateMode==='solo');
  document.getElementById('lyAboveBtn').classList.toggle('active',false);
  applyVisibility();
}
function toggleAbove(){
  isolateMode=isolateMode==='above'?'none':'above';
  document.getElementById('lyAboveBtn').classList.toggle('active',isolateMode==='above');
  document.getElementById('lyIsoBtn').classList.toggle('active',false);
  applyVisibility();
}
function resetVisibility(){
  isolateMode='none';
  document.getElementById('lyIsoBtn').classList.remove('active');
  document.getElementById('lyAboveBtn').classList.remove('active');
  applyVisibility();
}
function applyVisibility(){
  for(const[,e]of placed){
    if(isolateMode==='solo'){
      e.mesh.visible=e.gy===currentLayer;
    }else if(isolateMode==='above'){
      e.mesh.visible=e.gy<=currentLayer;
    }else{
      e.mesh.visible=true;
    }
  }
}

function deleteLayer(y){
  const toRemove=[];
  for(const[key,e]of placed){
    if(e.gy===y) toRemove.push(key);
  }
  if(toRemove.length===0)return;
  for(const key of toRemove){
    const e=placed.get(key);
    scene.remove(e.mesh);e.mesh.geometry.dispose();e.mesh.material.dispose();
    placed.delete(key);fires.delete(key);
  }
  // Trigger collapse check for all blocks above deleted layer
  for(const[,e]of placed){
    if(e.gy===y+1) schedCol(e.gx,e.gy,e.gz);
  }
  procCol();
  // Rebuild neighbor geometry for blocks adjacent to deleted layer
  for(const[,e]of placed){
    if(e.gy===y-1||e.gy===y+1) rebuildGeo(K(e.gx,e.gy,e.gz));
  }
  updateStats();
  if(dimMode==='2d')draw2d();
}

// ===== 2D PLAN VIEW =====
let dimMode='3d';
const c2d=document.getElementById('canvas2d');
const ctx2=c2d.getContext('2d');
let panX=0,panY=0,zoom2=18; // pixels per node
let pan2Drag=false,pan2X0=0,pan2Y0=0,panXS=0,panYS=0;
let hover2={gx:null,gz:null};

const BLOCK_COLORS={
  0:'#8a9bae',1:'#c75b3a',2:'#b08456',3:'#7dd8e8',
  4:'#5da84e',5:'#e2cc8a',6:'#9ca5b0',7:'#ffd166',
  8:'#3a8fd4',9:'#ff4422',10:'#ff6600',
  11:'#999994',12:'#d9d2c4',13:'#8b6e5a',14:'#d4d8dc',
  15:'#a67c52',16:'#e8e4db',
  17:'#7a5c3a',18:'#604830',19:'#a08a6a',20:'#888888',21:'#706050'
};
const BLOCK_COLORS_GHOST={
  0:'rgba(138,155,174,.15)',1:'rgba(199,91,58,.15)',2:'rgba(176,132,86,.15)',3:'rgba(125,216,232,.12)',
  4:'rgba(93,168,78,.12)',5:'rgba(226,204,138,.12)',6:'rgba(156,165,176,.15)',7:'rgba(255,209,102,.12)',
  8:'rgba(58,143,212,.12)',9:'rgba(255,68,34,.15)',10:'rgba(255,102,0,.15)',
  11:'rgba(153,153,148,.12)',12:'rgba(217,210,196,.1)',13:'rgba(139,110,90,.1)',14:'rgba(212,216,220,.08)',
  15:'rgba(166,124,82,.1)',16:'rgba(232,228,219,.08)',
  17:'rgba(122,92,58,.1)',18:'rgba(96,72,48,.1)',19:'rgba(160,138,106,.1)',20:'rgba(136,136,136,.08)',21:'rgba(112,96,80,.08)'
};

function setDim(d){
