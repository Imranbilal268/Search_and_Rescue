    }
    if(keysDown.has('s')||keysDown.has('arrowdown')){
      const fw=new THREE.Vector3(-Math.sin(cTh),0,-Math.cos(cTh));
      cTgtTarget.add(fw.multiplyScalar(-speed));
    }
    if(keysDown.has('a')||keysDown.has('arrowleft')){
      if(keysDown.has('shift')){
        const rt=new THREE.Vector3(-Math.cos(cTh),0,Math.sin(cTh));
        cTgtTarget.add(rt.multiplyScalar(-speed));
      }else{
        cThTarget-=.03;
      }
    }
    if(keysDown.has('d')||keysDown.has('arrowright')){
      if(keysDown.has('shift')){
        const rt=new THREE.Vector3(-Math.cos(cTh),0,Math.sin(cTh));
        cTgtTarget.add(rt.multiplyScalar(speed));
      }else{
        cThTarget+=.03;
      }
    }
    if(keysDown.has('q')) cPhTarget=Math.max(.05,cPhTarget-.02);
    if(keysDown.has('e')) cPhTarget=Math.min(Math.PI/2-.05,cPhTarget+.02);
    if(keysDown.has('=')||keysDown.has('+')) cDTarget=Math.max(3,cDTarget*.98);
    if(keysDown.has('-')||keysDown.has('_')) cDTarget=Math.min(200,cDTarget*1.02);
    if(keysDown.has(' ')){cTgtTarget.y+=speed*.5;}
    if(keysDown.has('c')){cTgtTarget.y-=speed*.5;}
  }
  // 2D pan/zoom with keyboard
  if(dimMode==='2d'){
    const sp=4;let moved=false;
    if(keysDown.has('w')||keysDown.has('arrowup')){panY+=sp;moved=true;}
    if(keysDown.has('s')||keysDown.has('arrowdown')){panY-=sp;moved=true;}
    if(keysDown.has('a')||keysDown.has('arrowleft')){panX+=sp;moved=true;}
    if(keysDown.has('d')||keysDown.has('arrowright')){panX-=sp;moved=true;}
    if(keysDown.has('=')||keysDown.has('+')){zoom2=Math.min(80,zoom2*1.02);moved=true;}
    if(keysDown.has('-')||keysDown.has('_')){zoom2=Math.max(4,zoom2*.98);moved=true;}
    if(moved) draw2d();
  }
