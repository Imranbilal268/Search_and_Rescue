  if(b.isFire){entry.onFire=true;fires.add(K(gx,gy,gz));for(const[dx,dy,dz]of D6){const nk=K(gx+dx,gy+dy,gz+dz),nb=placed.get(nk);if(nb&&!nb.onFire&&BLOCKS[nb.type].flamm>=1)ignite(nk,nb);}}
