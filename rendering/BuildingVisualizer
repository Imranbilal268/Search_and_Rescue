  {name:'FIRE',    color:0xff6600,emissive:0xff4400,emissiveI:1,flamm:0,maxHP:999,isFire:true},
  {name:'CONCRT',  color:0x999994,emissive:0x000000,flamm:0,maxHP:180},
  {name:'DRYWL',   color:0xd9d2c4,emissive:0x000000,flamm:2,maxHP:25},
  {name:'CARPET',  color:0x8b6e5a,emissive:0x020100,flamm:2,maxHP:15},
  {name:'TILE',    color:0xd4d8dc,emissive:0x000000,flamm:0,maxHP:90},
  {name:'FABRIC',  color:0xa67c52,emissive:0x030100,flamm:2,maxHP:10},
