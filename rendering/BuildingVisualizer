// ===== CAMERA (smooth orbit + pan + zoom) =====
let cTh=Math.PI/4, cPh=Math.PI/4.5, cD=55;
let cThTarget=cTh, cPhTarget=cPh, cDTarget=cD;
const cTgt=new THREE.Vector3(0,5,0);
const cTgtTarget=new THREE.Vector3(0,5,0);
const CAM_LERP=0.12; // smoothing factor

let orbiting=false, panning=false, pmx=0, pmy=0;

function updCam(){
  cPh=Math.max(.05,Math.min(Math.PI/2-.05,cPh));
  cD=Math.max(3,Math.min(200,cD));
  camera.position.x=cTgt.x+cD*Math.sin(cPh)*Math.cos(cTh);
  camera.position.y=cTgt.y+cD*Math.cos(cPh);
  camera.position.z=cTgt.z+cD*Math.sin(cPh)*Math.sin(cTh);
  camera.lookAt(cTgt);
  // Update cam info display
  const ci=document.getElementById('camInfo');
  if(ci) ci.textContent=cD.toFixed(0)+'m · '+Math.round(cPh*180/Math.PI)+'°';
}

function smoothCam(){
  const EPS=0.0001;
  const dTh=cThTarget-cTh, dPh=cPhTarget-cPh, dD=cDTarget-cD;
  const dX=cTgtTarget.x-cTgt.x, dY=cTgtTarget.y-cTgt.y, dZ=cTgtTarget.z-cTgt.z;
  // Snap to target if close enough (prevents perpetual micro-drift)
  if(Math.abs(dTh)<EPS&&Math.abs(dPh)<EPS&&Math.abs(dD)<EPS*10&&Math.abs(dX)<EPS&&Math.abs(dY)<EPS&&Math.abs(dZ)<EPS) return;
  cTh+=dTh*CAM_LERP; cPh+=dPh*CAM_LERP; cD+=dD*CAM_LERP;
  cTgt.x+=dX*CAM_LERP; cTgt.y+=dY*CAM_LERP; cTgt.z+=dZ*CAM_LERP;
  // Hard snap when extremely close
  if(Math.abs(cThTarget-cTh)<EPS) cTh=cThTarget;
  if(Math.abs(cPhTarget-cPh)<EPS) cPh=cPhTarget;
  if(Math.abs(cDTarget-cD)<EPS*10) cD=cDTarget;
  if(Math.abs(cTgtTarget.x-cTgt.x)<EPS) cTgt.x=cTgtTarget.x;
  if(Math.abs(cTgtTarget.y-cTgt.y)<EPS) cTgt.y=cTgtTarget.y;
  if(Math.abs(cTgtTarget.z-cTgt.z)<EPS) cTgt.z=cTgtTarget.z;
  updCam();
}

// --- Button controls ---
function camOrbit(dTh,dPh){cThTarget+=dTh;cPhTarget=Math.max(.05,Math.min(Math.PI/2-.05,cPhTarget+dPh));}
function camZoom(d){cDTarget=Math.max(3,Math.min(200,cDTarget+d));}
function camPan(dx,dz){
  const fw=new THREE.Vector3(-Math.sin(cTh),0,-Math.cos(cTh)); // forward on XZ plane
  const rt=new THREE.Vector3(-Math.cos(cTh),0,Math.sin(cTh));  // right on XZ plane
  const speed=cDTarget*.08;
  cTgtTarget.add(rt.multiplyScalar(dx*speed));
  cTgtTarget.add(fw.multiplyScalar(dz*speed));
}
function camReset(){
  cThTarget=Math.PI/4;cPhTarget=Math.PI/4.5;cDTarget=55;
  cTgtTarget.set(0,5,0);
}
function camFocus(){
  // Center on building bounding box
  if(placed.size===0){camReset();return;}
  let mx=0,my=0,mz=0,n=0;
  for(const[,e]of placed){mx+=e.gx;my+=e.gy;mz+=e.gz;n++;}
  cTgtTarget.set(mx/n,my/n,mz/n);
  // Fit zoom to building size
  let maxR=0;
  for(const[,e]of placed){
    const dx=e.gx-mx/n,dy=e.gy-my/n,dz2=e.gz-mz/n;
    maxR=Math.max(maxR,Math.sqrt(dx*dx+dy*dy+dz2*dz2));
  }
  cDTarget=Math.max(10,maxR*2.2);
}

