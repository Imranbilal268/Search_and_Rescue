function resize2d(){
  c2d.width=innerWidth;c2d.height=innerHeight;
  // Center on building
  if(placed.size>0&&panX===0&&panY===0){
    let sx=0,sz=0,n=0;
    for(const[,e]of placed){if(e.gy===currentLayer){sx+=e.gx;sz+=e.gz;n++;}}
    if(n>0){panX=innerWidth/2-sx/n*zoom2;panY=innerHeight/2-sz/n*zoom2;}
    else{panX=innerWidth/2;panY=innerHeight/2;}
  }
}

function worldToScreen2(gx,gz){return{x:gx*zoom2+panX,y:gz*zoom2+panY};}
function screenToWorld2(sx,sy){return{gx:Math.floor((sx-panX)/zoom2+.5),gz:Math.floor((sy-panY)/zoom2+.5)};}

function draw2d(){
  if(dimMode!=='2d')return;
  const W=c2d.width,H=c2d.height;
  ctx2.clearRect(0,0,W,H);
  ctx2.fillStyle='#0c0c14';ctx2.fillRect(0,0,W,H);
  const t=performance.now()*.001;
  const half=GRID/2;
  const z2=zoom2; // alias
  const wallTypes=new Set([Ty.STONE,Ty.BRICK,Ty.CONCRETE]);
  const solidTypes=new Set([Ty.STONE,Ty.BRICK,Ty.METAL,Ty.CONCRETE]);
  const partitionTypes=new Set([Ty.DRYWALL,Ty.PLASTER]);

  // Helper: is cell at gx,gz on current layer a wall/solid?
  function isWallAt(gx,gz){const e=placed.get(K(gx,currentLayer,gz));return e&&solidTypes.has(e.type);}
  function blockAt(gx,gz){return placed.get(K(gx,currentLayer,gz));}

  // --- GRID LINES ---
  ctx2.strokeStyle='rgba(255,255,255,.03)';ctx2.lineWidth=.5;
  for(let i=-half;i<=half;i++){
    const p1=worldToScreen2(i,-half),p2=worldToScreen2(i,half);
    ctx2.beginPath();ctx2.moveTo(p1.x,p1.y);ctx2.lineTo(p2.x,p2.y);ctx2.stroke();
    const p3=worldToScreen2(-half,i),p4=worldToScreen2(half,i);
    ctx2.beginPath();ctx2.moveTo(p3.x,p3.y);ctx2.lineTo(p4.x,p4.y);ctx2.stroke();
  }
  // Meter grid
  const mStep=Math.round(1/SCALE);
  ctx2.strokeStyle='rgba(91,240,165,.1)';ctx2.lineWidth=.8;
  for(let i=-half;i<=half;i+=mStep){
    const p1=worldToScreen2(i,-half),p2=worldToScreen2(i,half);
    ctx2.beginPath();ctx2.moveTo(p1.x,p1.y);ctx2.lineTo(p2.x,p2.y);ctx2.stroke();
    const p3=worldToScreen2(-half,i),p4=worldToScreen2(half,i);
    ctx2.beginPath();ctx2.moveTo(p3.x,p3.y);ctx2.lineTo(p4.x,p4.y);ctx2.stroke();
  }
  // Meter labels
  if(z2>8){
    ctx2.font='9px "JetBrains Mono",monospace';ctx2.fillStyle='rgba(91,240,165,.3)';
    ctx2.textAlign='center';
    for(let i=-half;i<=half;i+=mStep){const m=((i+half)*SCALE).toFixed(0);const p=worldToScreen2(i,-half);ctx2.fillText(m+'m',p.x,p.y-6);}
    ctx2.textAlign='right';
    for(let i=-half;i<=half;i+=mStep){const m=((i+half)*SCALE).toFixed(0);const p=worldToScreen2(-half,i);ctx2.fillText(m+'m',p.x-6,p.y+3);}
  }

  // --- GHOST LAYERS (above/below, very faint) ---
  for(const[,e]of placed){
    if(e.gy===currentLayer-1||e.gy===currentLayer+1){
      const p=worldToScreen2(e.gx,e.gz);
      ctx2.fillStyle=BLOCK_COLORS_GHOST[e.type]||'rgba(255,255,255,.03)';
      ctx2.fillRect(p.x-z2/2,p.y-z2/2,z2,z2);
    }
  }

  // --- PASS 1: FLOOR TILES (light background for open space) ---
  for(const[,e]of placed){
    if(e.gy!==currentLayer)continue;
    if(wallTypes.has(e.type)||solidTypes.has(e.type)||partitionTypes.has(e.type)||e.type===Ty.DOORPNL||e.type===Ty.DOORFRM||e.type===Ty.STAIRWL||e.type===Ty.RAILING||e.type===Ty.THRESHD)continue;
    const p=worldToScreen2(e.gx,e.gz);
    let col=BLOCK_COLORS[e.type]||'#888';
    // Damage
    if(e.integrity<1&&col.startsWith('#')){
      const d=1-e.integrity;
      const r=parseInt(col.slice(1,3),16),g=parseInt(col.slice(3,5),16),b=parseInt(col.slice(5,7),16);
      col=`rgb(${Math.floor(r*(1-d*.5))},${Math.floor(g*(1-d*.6))},${Math.floor(b*(1-d*.4))})`;
    }
    ctx2.fillStyle=col;
    // Opacity varies by type
    const floorAlpha=e.type===Ty.GLASS?0.35:e.type===Ty.WATER?0.5:e.type===Ty.CARPET?0.45:e.type===Ty.TILE?0.4:e.type===Ty.FABRIC?0.55:0.3;
    ctx2.globalAlpha=floorAlpha;
    ctx2.fillRect(p.x-z2/2,p.y-z2/2,z2,z2);
    ctx2.globalAlpha=1;

    // Type overlays
    if(e.type===Ty.GLASS&&z2>8){
      ctx2.strokeStyle='rgba(125,216,232,.6)';ctx2.lineWidth=1;
      const hasXnb=placed.has(K(e.gx+1,currentLayer,e.gz))||placed.has(K(e.gx-1,currentLayer,e.gz));
      const hasZnb=placed.has(K(e.gx,currentLayer,e.gz+1))||placed.has(K(e.gx,currentLayer,e.gz-1));
      if(hasXnb&&!hasZnb){
        ctx2.beginPath();ctx2.moveTo(p.x-z2/2,p.y-1);ctx2.lineTo(p.x+z2/2,p.y-1);ctx2.stroke();
        ctx2.beginPath();ctx2.moveTo(p.x-z2/2,p.y+1);ctx2.lineTo(p.x+z2/2,p.y+1);ctx2.stroke();
      }else{
        ctx2.beginPath();ctx2.moveTo(p.x-1,p.y-z2/2);ctx2.lineTo(p.x-1,p.y+z2/2);ctx2.stroke();
        ctx2.beginPath();ctx2.moveTo(p.x+1,p.y-z2/2);ctx2.lineTo(p.x+1,p.y+z2/2);ctx2.stroke();
      }
    }
    if(e.type===Ty.WOOD&&z2>10){
      ctx2.strokeStyle='rgba(80,50,20,.2)';ctx2.lineWidth=.5;
      for(let li=0;li<3;li++){const ly=p.y-z2/2+z2*.25+li*z2*.25;
        ctx2.beginPath();ctx2.moveTo(p.x-z2/2+1,ly);ctx2.lineTo(p.x+z2/2-1,ly);ctx2.stroke();}
    }
    if(e.type===Ty.CARPET&&z2>8){
      // Carpet: stipple dots
      ctx2.fillStyle='rgba(60,40,25,.2)';
      for(let di=0;di<4;di++){const dx2=(Math.sin(e.gx*7+di*2.3)*.35)*z2,dz2=(Math.cos(e.gz*5+di*1.7)*.35)*z2;
        ctx2.beginPath();ctx2.arc(p.x+dx2,p.y+dz2,1,0,Math.PI*2);ctx2.fill();}
    }
    if(e.type===Ty.TILE&&z2>8){
      // Tile: cross grid pattern
      ctx2.strokeStyle='rgba(180,185,195,.3)';ctx2.lineWidth=.5;
      ctx2.beginPath();ctx2.moveTo(p.x,p.y-z2/2);ctx2.lineTo(p.x,p.y+z2/2);ctx2.stroke();
      ctx2.beginPath();ctx2.moveTo(p.x-z2/2,p.y);ctx2.lineTo(p.x+z2/2,p.y);ctx2.stroke();
    }
    if(e.type===Ty.FABRIC){
      // Fabric/upholstery: soft rounded fill with subtle shading
      ctx2.fillStyle='rgba(166,124,82,.4)';
      const r2=z2*.35;
      ctx2.beginPath();ctx2.arc(p.x,p.y,r2,0,Math.PI*2);ctx2.fill();
      if(z2>10){ctx2.strokeStyle='rgba(120,80,40,.3)';ctx2.lineWidth=.5;ctx2.stroke();}
    }
    if(e.type===Ty.GLOW){
      const fl=.5+.3*Math.sin(t*3+e.gx);
      ctx2.fillStyle=`rgba(255,209,102,${fl})`;
      ctx2.beginPath();ctx2.arc(p.x,p.y,z2*.2,0,Math.PI*2);ctx2.fill();
    }
  }

  // --- PASS 2: WALLS — filled cells with connected borders ---
  // Draw all wall cells as filled, then draw thick outlines only on exposed faces
  const wallColor='#6B5B4F';const wallColorDark='#4A3E35';
  for(const[,e]of placed){
    if(e.gy!==currentLayer||!solidTypes.has(e.type))continue;
    const p=worldToScreen2(e.gx,e.gz);
    // Fill the wall cell solid
    let wc=e.type===Ty.METAL?'#7a8590':e.type===Ty.CONCRETE?'#8a8a86':e.type===Ty.STONE?'#7a8594':wallColor;
    if(e.integrity<1){
      const d=1-e.integrity;
      wc=`rgb(${Math.floor(107*(1-d*.5))},${Math.floor(91*(1-d*.5))},${Math.floor(79*(1-d*.5))})`;
    }
    ctx2.fillStyle=wc;
    ctx2.fillRect(p.x-z2/2,p.y-z2/2,z2,z2);
  }
  // Now draw thick outlines only on exposed faces
  ctx2.strokeStyle=wallColorDark;
  const wt=Math.max(1.5,z2*0.12); // wall line thickness scales with zoom
  ctx2.lineWidth=wt;
  for(const[,e]of placed){
    if(e.gy!==currentLayer||!solidTypes.has(e.type))continue;
    const p=worldToScreen2(e.gx,e.gz);
    const x1=p.x-z2/2,y1=p.y-z2/2,x2=p.x+z2/2,y2=p.y+z2/2;
    // Draw border only on faces NOT adjacent to another wall
    if(!isWallAt(e.gx,e.gz-1)){ctx2.beginPath();ctx2.moveTo(x1,y1);ctx2.lineTo(x2,y1);ctx2.stroke();} // top (north)
    if(!isWallAt(e.gx,e.gz+1)){ctx2.beginPath();ctx2.moveTo(x1,y2);ctx2.lineTo(x2,y2);ctx2.stroke();} // bottom (south)
    if(!isWallAt(e.gx-1,e.gz)){ctx2.beginPath();ctx2.moveTo(x1,y1);ctx2.lineTo(x1,y2);ctx2.stroke();} // left (west)
    if(!isWallAt(e.gx+1,e.gz)){ctx2.beginPath();ctx2.moveTo(x2,y1);ctx2.lineTo(x2,y2);ctx2.stroke();} // right (east)
  }

  // --- PASS 2b: PARTITION WALLS (drywall, plaster) — thinner, lighter ---
  function isPartAt(gx,gz){const e=placed.get(K(gx,currentLayer,gz));return e&&(partitionTypes.has(e.type)||solidTypes.has(e.type));}
  function isAnyWallAt(gx,gz){return isWallAt(gx,gz)||isPartAt(gx,gz);}
  for(const[,e]of placed){
    if(e.gy!==currentLayer||!partitionTypes.has(e.type))continue;
    const p=worldToScreen2(e.gx,e.gz);
    const pc=e.type===Ty.DRYWALL?'#c8c0b0':'#d8d4cc';
    ctx2.fillStyle=pc;
    ctx2.fillRect(p.x-z2/2+1,p.y-z2/2+1,z2-2,z2-2);
  }
  // Partition outlines (thinner than structural)
  ctx2.lineWidth=Math.max(1,z2*0.07);
  for(const[,e]of placed){
    if(e.gy!==currentLayer||!partitionTypes.has(e.type))continue;
    const p=worldToScreen2(e.gx,e.gz);
    ctx2.strokeStyle=e.type===Ty.DRYWALL?'#a09888':'#b8b4ac';
    const x1=p.x-z2/2,y1=p.y-z2/2,x2=p.x+z2/2,y2=p.y+z2/2;
    if(!isPartAt(e.gx,e.gz-1)){ctx2.beginPath();ctx2.moveTo(x1,y1);ctx2.lineTo(x2,y1);ctx2.stroke();}
    if(!isPartAt(e.gx,e.gz+1)){ctx2.beginPath();ctx2.moveTo(x1,y2);ctx2.lineTo(x2,y2);ctx2.stroke();}
    if(!isPartAt(e.gx-1,e.gz)){ctx2.beginPath();ctx2.moveTo(x1,y1);ctx2.lineTo(x1,y2);ctx2.stroke();}
    if(!isPartAt(e.gx+1,e.gz)){ctx2.beginPath();ctx2.moveTo(x2,y1);ctx2.lineTo(x2,y2);ctx2.stroke();}
  }

  // --- PASS 3: DOORS, STAIRS, RAILINGS — architectural symbols ---
  const doorTypes=new Set([Ty.DOORPNL,Ty.DOORFRM,Ty.THRESHD]);
  const stairTypes=new Set([Ty.STAIRWL]);
  let drawnStairs=new Set();
  for(const[,e]of placed){
    if(e.gy!==currentLayer)continue;

    // --- DOOR PANELS: proper architectural door symbol ---
    if(e.type===Ty.DOORPNL||e.type===Ty.DOORFRM){
      const p=worldToScreen2(e.gx,e.gz);
      // Clear wall cell
      ctx2.fillStyle='#0c0c14';
      ctx2.fillRect(p.x-z2/2+.5,p.y-z2/2+.5,z2-1,z2-1);
      // Light floor fill
      ctx2.fillStyle='rgba(112,96,80,.15)';
      ctx2.fillRect(p.x-z2/2+.5,p.y-z2/2+.5,z2-1,z2-1);

      if(e.type===Ty.DOORPNL&&z2>5){
        // Determine wall direction
        const wx2=isAnyWallAt(e.gx-1,e.gz)||isAnyWallAt(e.gx+1,e.gz);
        const wz2=isAnyWallAt(e.gx,e.gz-1)||isAnyWallAt(e.gx,e.gz+1);
        // Door leaf line (thick, short)
        ctx2.strokeStyle='rgba(122,92,58,.8)';ctx2.lineWidth=Math.max(2,z2*.1);
        if(wz2){ // wall runs along Z, door opens in X
          ctx2.beginPath();ctx2.moveTo(p.x-z2/2+1,p.y-z2*.35);ctx2.lineTo(p.x-z2/2+1,p.y+z2*.35);ctx2.stroke();
          // Swing arc
          if(z2>8){
            ctx2.strokeStyle='rgba(122,92,58,.35)';ctx2.lineWidth=.8;ctx2.setLineDash([2,2]);
            ctx2.beginPath();ctx2.arc(p.x-z2/2+1,p.y-z2*.35,z2*.7,-Math.PI*.05,Math.PI*.42);ctx2.stroke();
            ctx2.setLineDash([]);
          }
        }else{ // wall runs along X, door opens in Z
          ctx2.beginPath();ctx2.moveTo(p.x-z2*.35,p.y-z2/2+1);ctx2.lineTo(p.x+z2*.35,p.y-z2/2+1);ctx2.stroke();
          if(z2>8){
            ctx2.strokeStyle='rgba(122,92,58,.35)';ctx2.lineWidth=.8;ctx2.setLineDash([2,2]);
            ctx2.beginPath();ctx2.arc(p.x-z2*.35,p.y-z2/2+1,z2*.7,Math.PI*.05,Math.PI*.45);ctx2.stroke();
            ctx2.setLineDash([]);
          }
        }
        // Frame ticks at jamb ends
        ctx2.strokeStyle='rgba(96,72,48,.7)';ctx2.lineWidth=Math.max(1.5,z2*.06);
        if(wz2){
          ctx2.beginPath();ctx2.moveTo(p.x-z2/2,p.y-z2/2);ctx2.lineTo(p.x-z2/2+z2*.15,p.y-z2/2);ctx2.stroke();
          ctx2.beginPath();ctx2.moveTo(p.x-z2/2,p.y+z2/2);ctx2.lineTo(p.x-z2/2+z2*.15,p.y+z2/2);ctx2.stroke();
          ctx2.beginPath();ctx2.moveTo(p.x+z2/2,p.y-z2/2);ctx2.lineTo(p.x+z2/2-z2*.15,p.y-z2/2);ctx2.stroke();
          ctx2.beginPath();ctx2.moveTo(p.x+z2/2,p.y+z2/2);ctx2.lineTo(p.x+z2/2-z2*.15,p.y+z2/2);ctx2.stroke();
        }else{
          ctx2.beginPath();ctx2.moveTo(p.x-z2/2,p.y-z2/2);ctx2.lineTo(p.x-z2/2,p.y-z2/2+z2*.15);ctx2.stroke();
          ctx2.beginPath();ctx2.moveTo(p.x+z2/2,p.y-z2/2);ctx2.lineTo(p.x+z2/2,p.y-z2/2+z2*.15);ctx2.stroke();
          ctx2.beginPath();ctx2.moveTo(p.x-z2/2,p.y+z2/2);ctx2.lineTo(p.x-z2/2,p.y+z2/2-z2*.15);ctx2.stroke();
          ctx2.beginPath();ctx2.moveTo(p.x+z2/2,p.y+z2/2);ctx2.lineTo(p.x+z2/2,p.y+z2/2-z2*.15);ctx2.stroke();
        }
      }
    }

    // --- THRESHOLD: entrance marker ---
    if(e.type===Ty.THRESHD){
      const p=worldToScreen2(e.gx,e.gz);
      ctx2.fillStyle='rgba(112,96,80,.35)';
      ctx2.fillRect(p.x-z2/2+1,p.y-z2/2+1,z2-2,z2-2);
      if(z2>10){
        ctx2.strokeStyle='rgba(112,96,80,.5)';ctx2.lineWidth=1;
        ctx2.setLineDash([3,2]);
        ctx2.strokeRect(p.x-z2/2+2,p.y-z2/2+2,z2-4,z2-4);
        ctx2.setLineDash([]);
      }
    }

    // --- STAIR TREADS: connected region detection + proper step lines ---
    if(e.type===Ty.STAIRWL){
      const p=worldToScreen2(e.gx,e.gz);
      // Find connected stair region from this cell
      const stKey=e.gx+','+e.gz;
      if(!drawnStairs.has(stKey)){
        // Flood-fill to find all connected STEPTRD cells on this layer
        const regionCells=[];
        const stVisited=new Set();
        const stQueue=[[e.gx,e.gz]];stVisited.add(stKey);
        while(stQueue.length){
          const[sx,sz]=stQueue.shift();
          const se=placed.get(K(sx,currentLayer,sz));
          if(!se)continue;
          // Accept STEPTRD, RAILING, CONCRETE under stairs
          if(se.type===Ty.STAIRWL) regionCells.push([sx,sz]);
          drawnStairs.add(sx+','+sz);
          for(const[dx2,dz2]of[[1,0],[-1,0],[0,1],[0,-1]]){
            const nk=K(sx+dx2,currentLayer,sz+dz2);
            const nkStr=(sx+dx2)+','+(sz+dz2);
            if(!stVisited.has(nkStr)){
              const ne=placed.get(nk);
              if(ne&&ne.type===Ty.STAIRWL){stVisited.add(nkStr);stQueue.push([sx+dx2,sz+dz2]);}
            }
          }
        }
        if(regionCells.length===0){regionCells.push([e.gx,e.gz]);}

        // Bounding box of region
        let rMinX=Infinity,rMaxX=-Infinity,rMinZ=Infinity,rMaxZ=-Infinity;
        for(const[rx,rz]of regionCells){rMinX=Math.min(rMinX,rx);rMaxX=Math.max(rMaxX,rx);rMinZ=Math.min(rMinZ,rz);rMaxZ=Math.max(rMaxZ,rz);}
        const rSpanX=rMaxX-rMinX+1, rSpanZ=rMaxZ-rMinZ+1;
        const runAlongZ2=rSpanZ>=rSpanX;
        const runLen2=runAlongZ2?rSpanZ:rSpanX;

        // Draw filled stair region background
        for(const[rx,rz]of regionCells){
          const rp=worldToScreen2(rx,rz);
          ctx2.fillStyle='rgba(160,138,106,.3)';
          ctx2.fillRect(rp.x-z2/2,rp.y-z2/2,z2,z2);
        }

        // Draw step lines across the entire region
        if(z2>5){
          const numSteps=Math.max(3,runLen2*2);
          ctx2.strokeStyle='rgba(100,80,55,.45)';ctx2.lineWidth=Math.max(.6,z2*.04);
          if(runAlongZ2){
            // Steps run N-S: horizontal lines across the full width
            const px1=worldToScreen2(rMinX,rMinZ);
            const px2=worldToScreen2(rMaxX,rMaxZ);
            const left=px1.x-z2/2+2, right=px2.x+z2/2-2;
            const top=px1.y-z2/2, bottom=px2.y+z2/2;
            for(let s=0;s<=numSteps;s++){
              const sy=top+(bottom-top)*(s/numSteps);
              ctx2.beginPath();ctx2.moveTo(left,sy);ctx2.lineTo(right,sy);ctx2.stroke();
            }
            // Direction arrow (pointing toward higher step = "up")
            if(z2>8){
              const cx2=(left+right)/2, cy2=(top+bottom)/2;
              ctx2.fillStyle='rgba(100,80,55,.6)';
              ctx2.beginPath();
              ctx2.moveTo(cx2,top+z2*.3);ctx2.lineTo(cx2-z2*.2,top+z2*.7);ctx2.lineTo(cx2+z2*.2,top+z2*.7);
              ctx2.fill();
            }
          }else{
            // Steps run E-W: vertical lines across the full depth
            const pz1=worldToScreen2(rMinX,rMinZ);
            const pz2=worldToScreen2(rMaxX,rMaxZ);
            const left=pz1.x-z2/2, right=pz2.x+z2/2;
            const top=pz1.y-z2/2+2, bottom=pz2.y+z2/2-2;
            for(let s=0;s<=numSteps;s++){
              const sx2=left+(right-left)*(s/numSteps);
              ctx2.beginPath();ctx2.moveTo(sx2,top);ctx2.lineTo(sx2,bottom);ctx2.stroke();
            }
            if(z2>8){
              const cx2=(left+right)/2, cy2=(top+bottom)/2;
              ctx2.fillStyle='rgba(100,80,55,.6)';
              ctx2.beginPath();
              ctx2.moveTo(right-z2*.3,cy2);ctx2.lineTo(right-z2*.7,cy2-z2*.2);ctx2.lineTo(right-z2*.7,cy2+z2*.2);
              ctx2.fill();
            }
          }
        }

        // Stair region border
        for(const[rx,rz]of regionCells){
          const rp=worldToScreen2(rx,rz);
          // Only draw border on exposed faces
          const inRegion=(dx2,dz2)=>regionCells.some(([cx,cz])=>cx===rx+dx2&&cz===rz+dz2);
          ctx2.strokeStyle='rgba(80,65,45,.4)';ctx2.lineWidth=Math.max(.8,z2*.05);
          if(!inRegion(0,-1)){ctx2.beginPath();ctx2.moveTo(rp.x-z2/2,rp.y-z2/2);ctx2.lineTo(rp.x+z2/2,rp.y-z2/2);ctx2.stroke();}
          if(!inRegion(0,1)){ctx2.beginPath();ctx2.moveTo(rp.x-z2/2,rp.y+z2/2);ctx2.lineTo(rp.x+z2/2,rp.y+z2/2);ctx2.stroke();}
          if(!inRegion(-1,0)){ctx2.beginPath();ctx2.moveTo(rp.x-z2/2,rp.y-z2/2);ctx2.lineTo(rp.x-z2/2,rp.y+z2/2);ctx2.stroke();}
          if(!inRegion(1,0)){ctx2.beginPath();ctx2.moveTo(rp.x+z2/2,rp.y-z2/2);ctx2.lineTo(rp.x+z2/2,rp.y+z2/2);ctx2.stroke();}
        }

        // "UP" label
        if(z2>12&&regionCells.length>=2){
          const cx3=(worldToScreen2(rMinX,rMinZ).x+worldToScreen2(rMaxX,rMaxZ).x)/2;
          const cy3=(worldToScreen2(rMinX,rMinZ).y+worldToScreen2(rMaxX,rMaxZ).y)/2;
          ctx2.font='bold '+Math.max(7,z2*.35)+'px "JetBrains Mono",monospace';
          ctx2.fillStyle='rgba(100,80,55,.4)';ctx2.textAlign='center';ctx2.textBaseline='middle';
          ctx2.fillText('UP',cx3,cy3+z2*.5);
        }
      }
    }

    // --- RAILINGS: thin line with posts ---
    if(e.type===Ty.RAILING){
      const p=worldToScreen2(e.gx,e.gz);
      ctx2.strokeStyle='rgba(136,136,136,.5)';ctx2.lineWidth=Math.max(1.2,z2*.06);
      // Find connected railing direction
      const hasRailX=placed.has(K(e.gx+1,currentLayer,e.gz))&&placed.get(K(e.gx+1,currentLayer,e.gz)).type===Ty.RAILING;
      const hasRailZ=placed.has(K(e.gx,currentLayer,e.gz+1))&&placed.get(K(e.gx,currentLayer,e.gz+1)).type===Ty.RAILING;
      const hasStairNb=(dx2,dz2)=>{const ne=placed.get(K(e.gx+dx2,currentLayer,e.gz+dz2));return ne&&ne.type===Ty.STAIRWL;};
      // Draw railing line perpendicular to adjacent stair run
      if(hasStairNb(1,0)||hasStairNb(-1,0)){
        // Stairs on X side: railing runs along Z
        ctx2.beginPath();ctx2.moveTo(p.x,p.y-z2/2);ctx2.lineTo(p.x,p.y+z2/2);ctx2.stroke();
      }else if(hasStairNb(0,1)||hasStairNb(0,-1)){
        // Stairs on Z side: railing runs along X
        ctx2.beginPath();ctx2.moveTo(p.x-z2/2,p.y);ctx2.lineTo(p.x+z2/2,p.y);ctx2.stroke();
      }else if(hasRailX){
        ctx2.beginPath();ctx2.moveTo(p.x-z2/2,p.y);ctx2.lineTo(p.x+z2/2,p.y);ctx2.stroke();
      }else{
        ctx2.beginPath();ctx2.moveTo(p.x,p.y-z2/2);ctx2.lineTo(p.x,p.y+z2/2);ctx2.stroke();
      }
      if(z2>8){ctx2.fillStyle='rgba(136,136,136,.45)';ctx2.beginPath();ctx2.arc(p.x,p.y,1.5,0,Math.PI*2);ctx2.fill();}
    }

    // --- ALSO detect old WOOD-between-walls doors (backward compat) ---
    if(e.type===Ty.WOOD){
      const wx3=isAnyWallAt(e.gx-1,e.gz)||isAnyWallAt(e.gx+1,e.gz);
      const wz3=isAnyWallAt(e.gx,e.gz-1)||isAnyWallAt(e.gx,e.gz+1);
      if(wx3||wz3){
        const hasDoorAbove=placed.has(K(e.gx,currentLayer+1,e.gz))&&placed.get(K(e.gx,currentLayer+1,e.gz)).type===Ty.DOORPNL;
        const hasDoorBelow=placed.has(K(e.gx,currentLayer-1,e.gz))&&placed.get(K(e.gx,currentLayer-1,e.gz)).type===Ty.DOORFRM;
        if(!hasDoorAbove&&!hasDoorBelow){
          // Legacy wood door — render basic door symbol
          const p=worldToScreen2(e.gx,e.gz);
          ctx2.fillStyle='#0c0c14';ctx2.fillRect(p.x-z2/2+.5,p.y-z2/2+.5,z2-1,z2-1);
          ctx2.fillStyle='rgba(176,132,86,.15)';ctx2.fillRect(p.x-z2/2+.5,p.y-z2/2+.5,z2-1,z2-1);
          if(z2>6){
            ctx2.strokeStyle='rgba(176,132,86,.5)';ctx2.lineWidth=1;ctx2.setLineDash([2,2]);
            const r=z2*.4;
            if(wx3){ctx2.beginPath();ctx2.arc(p.x-z2/3,p.y,r,-.5,.8);ctx2.stroke();}
            else{ctx2.beginPath();ctx2.arc(p.x,p.y-z2/3,r,.3,1.5);ctx2.stroke();}
            ctx2.setLineDash([]);
          }
        }
      }
    }
  }

  // --- PASS 4: FIRE EFFECTS ---
  for(const[,e]of placed){
    if(e.gy!==currentLayer||!e.onFire)continue;
    const p=worldToScreen2(e.gx,e.gz);
    const flicker=.6+.4*Math.sin(t*8+e.gx*3+e.gz*5);
    // Glow halo
    const grd=ctx2.createRadialGradient(p.x,p.y,z2*.2,p.x,p.y,z2*2.5);
    grd.addColorStop(0,`rgba(255,100,20,${.15*flicker})`);grd.addColorStop(1,'rgba(255,60,10,0)');
    ctx2.fillStyle=grd;ctx2.fillRect(p.x-z2*3,p.y-z2*3,z2*6,z2*6);
    // Fire center
    ctx2.fillStyle=`rgba(255,${Math.floor(60+80*flicker)},0,${.6+.3*flicker})`;
    ctx2.beginPath();ctx2.arc(p.x,p.y,z2*.35,0,Math.PI*2);ctx2.fill();
    if(z2>10){
      ctx2.fillStyle=`rgba(255,220,80,${.4*flicker})`;
      ctx2.beginPath();ctx2.arc(p.x,p.y,z2*.15,0,Math.PI*2);ctx2.fill();
    }
  }

  // --- ROOM LABELS ---
  if(roomLabels2D.length>0&&z2>6){
    ctx2.font=z2>14?'bold 13px "Outfit",sans-serif':(z2>9?'bold 10px "Outfit",sans-serif':'bold 8px "Outfit",sans-serif');
    ctx2.fillStyle='rgba(255,255,255,.5)';ctx2.textAlign='center';ctx2.textBaseline='middle';
    for(const rl of roomLabels2D){
      if(Math.abs(rl.y-currentLayer)>2)continue;
      const p=worldToScreen2(rl.x,rl.z);
      ctx2.fillText(rl.text,p.x,p.y);
    }
  }

  // --- HOVER CURSOR ---
  if(hover2.gx!==null){
    const p=worldToScreen2(hover2.gx,hover2.gz);
    const existingKey=K(hover2.gx,currentLayer,hover2.gz);
    const existing=placed.get(existingKey);
    if(mode==='place'){
      const bc=BLOCKS[selectedBlock];
      // Show block color swatch in cursor
      const cc=BLOCK_COLORS[selectedBlock]||'#888';
      ctx2.fillStyle=bc.isFire?'rgba(255,100,0,.25)':cc;
      ctx2.globalAlpha=0.3;
      ctx2.fillRect(p.x-z2/2,p.y-z2/2,z2,z2);
      ctx2.globalAlpha=1;
      ctx2.strokeStyle=bc.isFire?'rgba(255,100,0,.6)':'rgba(91,240,165,.5)';
      ctx2.lineWidth=1.5;ctx2.strokeRect(p.x-z2/2,p.y-z2/2,z2,z2);
      // Block type label
      if(z2>8){
        ctx2.font='bold 8px "JetBrains Mono",monospace';ctx2.fillStyle='rgba(91,240,165,.5)';ctx2.textAlign='left';
        ctx2.fillText(bc.name,p.x+z2/2+4,p.y-4);
        ctx2.font='8px "JetBrains Mono",monospace';ctx2.fillStyle='rgba(255,255,255,.2)';
        ctx2.fillText('('+hover2.gx+','+hover2.gz+')',p.x+z2/2+4,p.y+6);
      }
    }else{
      // Erase mode: show X and existing block info
      ctx2.strokeStyle='rgba(255,80,80,.6)';ctx2.lineWidth=1.5;
      ctx2.strokeRect(p.x-z2/2,p.y-z2/2,z2,z2);
      if(existing){
        ctx2.fillStyle='rgba(255,60,60,.12)';
        ctx2.fillRect(p.x-z2/2,p.y-z2/2,z2,z2);
        ctx2.beginPath();ctx2.moveTo(p.x-z2*.3,p.y-z2*.3);ctx2.lineTo(p.x+z2*.3,p.y+z2*.3);ctx2.stroke();
        ctx2.beginPath();ctx2.moveTo(p.x+z2*.3,p.y-z2*.3);ctx2.lineTo(p.x-z2*.3,p.y+z2*.3);ctx2.stroke();
        if(z2>8){
          ctx2.font='bold 8px "JetBrains Mono",monospace';ctx2.fillStyle='rgba(255,100,100,.5)';ctx2.textAlign='left';
          ctx2.fillText(BLOCKS[existing.type].name,p.x+z2/2+4,p.y-4);
        }
      }else{
        // Empty cell in erase mode: dim cursor
        ctx2.setLineDash([3,3]);ctx2.strokeRect(p.x-z2/2,p.y-z2/2,z2,z2);ctx2.setLineDash([]);
      }
    }
  }

  // --- SCALE BAR ---
  const barPx=mStep*z2,bx=20,by=H-30;
  ctx2.strokeStyle='rgba(91,240,165,.5)';ctx2.lineWidth=1.5;
  ctx2.beginPath();ctx2.moveTo(bx,by);ctx2.lineTo(bx+barPx,by);ctx2.stroke();
  ctx2.beginPath();ctx2.moveTo(bx,by-4);ctx2.lineTo(bx,by+4);ctx2.stroke();
  ctx2.beginPath();ctx2.moveTo(bx+barPx,by-4);ctx2.lineTo(bx+barPx,by+4);ctx2.stroke();
  ctx2.font='10px "JetBrains Mono",monospace';ctx2.fillStyle='rgba(91,240,165,.5)';ctx2.textAlign='center';
  ctx2.fillText('1.0m',bx+barPx/2,by-8);
  // Compass
  ctx2.fillStyle='rgba(255,255,255,.2)';ctx2.font='10px "JetBrains Mono",monospace';ctx2.textAlign='center';
  ctx2.fillText('N',W-30,30);ctx2.fillText('S',W-30,H-50);
  ctx2.fillText('W',W-55,H/2);ctx2.fillText('E',W-8,H/2);
  // Plan info
  document.getElementById('pi-y').textContent=currentLayer;
  document.getElementById('pi-m').textContent=(currentLayer*SCALE).toFixed(2)+'m';
}

// Store room labels for 2D rendering
let roomLabels2D=[];

// 2D input handlers
let paint2=false,erase2=false;
c2d.addEventListener('mousedown',e=>{
  // Ctrl+LMB = eyedropper (pick block type under cursor)
  if(e.button===0&&e.ctrlKey){
    const w=screenToWorld2(e.clientX,e.clientY);
    const key=K(w.gx,currentLayer,w.gz);
    const blk=placed.get(key);
    if(blk){
      selectedBlock=blk.type;
      document.querySelectorAll('.block-btn').forEach((b,i)=>b.classList.toggle('active',i===selectedBlock));
      setMode('place');
    }
    e.preventDefault();draw2d();return;
  }
  // MMB or Alt+LMB = pan
  if(e.button===1||(e.button===0&&e.altKey)){
    pan2Drag=true;pan2X0=e.clientX;pan2Y0=e.clientY;panXS=panX;panYS=panY;e.preventDefault();return;
  }
  // LMB = place (or erase in erase mode) with drag
  if(e.button===0){
    const w=screenToWorld2(e.clientX,e.clientY);
    if(mode==='place'){createBlock(w.gx,currentLayer,w.gz);paint2=true;}
    else{const key=K(w.gx,currentLayer,w.gz);if(placed.has(key))removeBlock(w.gx,currentLayer,w.gz);erase2=true;}
    draw2d();return;
  }
  // RMB = erase with drag
  if(e.button===2){
    const w=screenToWorld2(e.clientX,e.clientY);
    const key=K(w.gx,currentLayer,w.gz);
    if(placed.has(key)) removeBlock(w.gx,currentLayer,w.gz);
    erase2=true;draw2d();
  }
});
c2d.addEventListener('mousemove',e=>{
  if(pan2Drag){
    panX=panXS+(e.clientX-pan2X0);panY=panYS+(e.clientY-pan2Y0);draw2d();return;
  }
  const w=screenToWorld2(e.clientX,e.clientY);
  hover2.gx=w.gx;hover2.gz=w.gz;
  // Drag painting
  if(paint2&&mode==='place'){
    createBlock(w.gx,currentLayer,w.gz);
  }
  // Drag erasing (LMB in erase mode or RMB)
  if(erase2){
    const key=K(w.gx,currentLayer,w.gz);
    if(placed.has(key)) removeBlock(w.gx,currentLayer,w.gz);
  }
  draw2d();
});
c2d.addEventListener('mouseup',e=>{pan2Drag=false;paint2=false;erase2=false;});
c2d.addEventListener('wheel',e=>{
  e.preventDefault();
  if(e.shiftKey){
    layerStep(e.deltaY>0?-1:1);return;
  }
  const mx=e.clientX,my=e.clientY;
  const wBefore=screenToWorld2(mx,my);
  const factor=e.deltaY>0?0.85:1.18;
  zoom2=Math.max(4,Math.min(80,zoom2*factor));
  const wAfter=screenToWorld2(mx,my);
  panX+=(wAfter.gx-wBefore.gx)*zoom2;panY+=(wAfter.gz-wBefore.gz)*zoom2;
  draw2d();
},{passive:false});
c2d.addEventListener('contextmenu',e=>e.preventDefault());

// Touch for 2D
let t2S=0,t2M=false,t2D=0,t2Paint=false;
c2d.addEventListener('touchstart',e=>{
  e.preventDefault();t2S=Date.now();t2M=false;t2Paint=false;
  if(e.touches.length===1){pan2X0=e.touches[0].clientX;pan2Y0=e.touches[0].clientY;panXS=panX;panYS=panY;}
  else if(e.touches.length===2){t2D=Math.hypot(e.touches[0].clientX-e.touches[1].clientX,e.touches[0].clientY-e.touches[1].clientY);}
},{passive:false});
c2d.addEventListener('touchmove',e=>{
  e.preventDefault();t2M=true;
  if(e.touches.length===1){
    const dx=e.touches[0].clientX-pan2X0,dy=e.touches[0].clientY-pan2Y0;
    const dist=Math.sqrt(dx*dx+dy*dy);
    if(dist>10&&!t2Paint){
      // Start panning if moved enough
      panX=panXS+dx;panY=panYS+dy;draw2d();
    }else if(t2Paint){
      // Drag painting with finger
      const w=screenToWorld2(e.touches[0].clientX,e.touches[0].clientY);
      if(mode==='place') createBlock(w.gx,currentLayer,w.gz);
      else{const key=K(w.gx,currentLayer,w.gz);if(placed.has(key))removeBlock(w.gx,currentLayer,w.gz);}
      draw2d();
    }
  }
  else if(e.touches.length===2){
    const d=Math.hypot(e.touches[0].clientX-e.touches[1].clientX,e.touches[0].clientY-e.touches[1].clientY);
    zoom2=Math.max(4,Math.min(80,zoom2*(d/t2D)));t2D=d;draw2d();}
},{passive:false});
c2d.addEventListener('touchend',e=>{
  if(!t2M&&Date.now()-t2S<300){
    const tx=e.changedTouches[0].clientX,ty=e.changedTouches[0].clientY;
    const w=screenToWorld2(tx,ty);
    if(mode==='place') createBlock(w.gx,currentLayer,w.gz);
    else{const key=K(w.gx,currentLayer,w.gz);if(placed.has(key))removeBlock(w.gx,currentLayer,w.gz);}
    draw2d();
  }
  t2Paint=false;
});

window.addEventListener('resize',()=>{
  camera.aspect=innerWidth/innerHeight;camera.updateProjectionMatrix();renderer.setSize(innerWidth,innerHeight);
  if(dimMode==='2d'){resize2d();draw2d();}
});

let lastT=performance.now();
let physicsPaused=false;
function togglePhysics(){
  physicsPaused=!physicsPaused;
  document.getElementById('physBtn').classList.toggle('active',!physicsPaused);
  document.getElementById('physBtn').textContent=physicsPaused?'▶ Play':'⏸ Pause';
}
function animate(){requestAnimationFrame(animate);const now=performance.now(),dt=Math.min((now-lastT)/1000,.1);lastT=now;if(!physicsPaused){fTmr+=dt;if(fTmr>=FT){fTmr-=FT;tickFire();procCol();updateStats();if(dimMode==='2d')draw2d();}updFireVis(dt);updateP(dt);updFall(dt);}processKeys();smoothCam();if(dimMode==='3d'){const pos=getGridPos();if(pos&&mode==='place'&&!pos.erase&&!orbiting&&!panning){ghost.visible=true;ghost.position.set(pos.gx,pos.gy+.45,pos.gz);ghostMat.color.setHex(BLOCKS[selectedBlock].isFire?0xff6600:BLOCKS[selectedBlock].color);}else ghost.visible=false;renderer.render(scene,camera);}}
animate();
</script>
