// Creates a stepped block: S steps rising from z=-d/2 to z=+d/2, total height = rise
function createStairGeo(rise,S){
  S=S||4;
  const w=0.96,d=0.96;
  const pos=[],idx=[];
  for(let i=0;i<S;i++){
    const y1=(i+1)*rise/S;
    const z0=-d/2+i*d/S, z1=-d/2+(i+1)*d/S;
    const x0=-w/2, x1=w/2;
    const v=pos.length/3;
    // Front face (riser): full height from 0 to y1
    // Back face: same height
    pos.push(x0,0,z0, x1,0,z0, x1,y1,z0, x0,y1,z0,
             x0,0,z1, x1,0,z1, x1,y1,z1, x0,y1,z1);
    idx.push(v,v+1,v+2,v,v+2,v+3,       // front
             v+5,v+4,v+7,v+5,v+7,v+6,   // back
             v+3,v+2,v+6,v+3,v+6,v+7,   // top
             v+4,v+5,v+1,v+4,v+1,v,     // bottom
             v+4,v,v+3,v+4,v+3,v+7,     // left
             v+1,v+5,v+6,v+1,v+6,v+2);  // right
  }
  const g=new THREE.BufferGeometry();
  g.setAttribute('position',new THREE.Float32BufferAttribute(pos,3));
  g.setIndex(idx);g.computeVertexNormals();return g;
}

