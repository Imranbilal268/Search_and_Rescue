    }
    if(f<FL-1){
      o.push([ox+14,by+1,oz+7,Ty.WOOD]);
      o.push([ox+15,by+2,oz+8,Ty.WOOD]);
    }
    // Restrooms (x=0..2, z=6..9) — brick partitions
    for(let h=1;h<=2;h++){
      o.push([ox+2,by+h,oz+6,Ty.BRICK]);
      o.push([ox+2,by+h,oz+7,Ty.BRICK]);
      o.push([ox+2,by+h,oz+8,Ty.BRICK]);
      o.push([ox+1,by+h,oz+7,Ty.BRICK]); // stall divider
    }
    o.push([ox+2,by+1,oz+6,Ty.WOOD]); // restroom door
