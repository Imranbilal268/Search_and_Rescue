// ===== FORMAT-UNIVERSAL HELPERS =====
// Extract array of floor grids from any JSON shape:
//   A: building.grid = [[floor0rows],[floor1rows]]
//   B: building.floors = [{grid:{rows:[...]}}, ...]
//   C: building.floors = [{grid:[[...]]}, ...]
function extractFloorGrids(b){
  if(b.grid&&Array.isArray(b.grid)&&b.grid.length>0&&Array.isArray(b.grid[0])&&Array.isArray(b.grid[0][0]))
    return b.grid;
  if(b.floors&&Array.isArray(b.floors))
    return b.floors.map(f=>{if(!f.grid)return null;if(Array.isArray(f.grid))return f.grid;if(f.grid.rows&&Array.isArray(f.grid.rows))return f.grid.rows;return null;}).filter(Boolean);
  return [];
}
function gridDims(grid){
  if(!grid||!grid.length)return{cols:0,numRows:0};
  return{cols:grid[0].length,numRows:grid.length};
}
function parseCoord(s){
  const xrf=s.match(/x(\d+),\s*(?:z|row)(\d+),\s*f(\d+)/);
  if(xrf)return{x:parseInt(xrf[1]),z:parseInt(xrf[2]),f:parseInt(xrf[3])};
  const xr=s.match(/x(\d+),\s*(?:z|row)(\d+)/);
  if(xr)return{x:parseInt(xr[1]),z:parseInt(xr[2]),f:0};
  const parts=s.split(',').map(p=>parseInt(p.trim()));
  return{x:parts[0]||0,z:parts[1]||0,f:parts[2]||0};
}
function flattenFloorMap(obj){
  const result=[];
  for(const[key,val]of Object.entries(obj)){
    if(typeof val==='string'){result.push({coord:key,label:val,floorIdx:0});}
    else if(typeof val==='object'&&val!==null&&!Array.isArray(val)){
      if(val.label&&typeof val.label==='string'){result.push({coord:key,label:val.label,floorIdx:0});}
      else{const fm=key.match(/(\d+)/);const fi=fm?parseInt(fm[1])-1:0;
        for(const[c2,v2]of Object.entries(val)){
          if(typeof v2==='string')result.push({coord:c2,label:v2,floorIdx:fi});
          else if(typeof v2==='object'&&v2&&v2.label)result.push({coord:c2,label:v2.label,floorIdx:fi});
        }
      }
    }
  }
  return result;
}
function resolveMat(mat,cellType,defaults){
  const m=(mat||(defaults&&defaults[cellType])||'').toLowerCase();
  if(m==='concrete')return Ty.CONCRETE;if(m==='brick')return Ty.BRICK;if(m==='stone')return Ty.STONE;
  if(m==='drywall')return Ty.DRYWALL;if(m==='metal'||m==='steel')return Ty.METAL;
  if(m==='wood')return Ty.WOOD;if(m==='glass')return Ty.GLASS;if(m==='tile')return Ty.TILE;
  if(m==='carpet')return Ty.CARPET;if(m==='plaster')return Ty.PLASTER;if(m==='fabric')return Ty.FABRIC;
  return null;
}

function parseFloorplanJSON(json){
  const blocks=[];
  const b=json.building||json;
  const floorGrids=extractFloorGrids(b);
  const WALL_H=3;
  const mats=b.materials||{};

  for(let fi=0;fi<floorGrids.length;fi++){
    const grid=floorGrids[fi];
    if(!grid||!grid.length)continue;
    const numRows=grid.length,numCols=grid[0].length;
    const baseY=fi*(WALL_H+1);
    const ox=-Math.floor(numCols/2),oz=-Math.floor(numRows/2);

    for(let row=0;row<numRows;row++){
      for(let col=0;col<numCols;col++){
        const rawCell=grid[row][col];
        const bx=ox+col,bz=oz+row;
        const pts=rawCell.split(':');
        const cell=pts[0].trim().toLowerCase();
        const mat=(pts[1]||'').trim().toLowerCase();
        const isPerimeter=(row===0||row===numRows-1||col===0||col===numCols-1);
        const wallMat=resolveMat(mat,'wall',mats)||(isPerimeter?Ty.BRICK:Ty.DRYWALL);

        switch(cell){
          case 'wall':case 'exterior_wall':{
            blocks.push([bx,baseY,bz,Ty.CONCRETE]);
            const wt=resolveMat(mat,'wall',mats)||(isPerimeter?Ty.BRICK:Ty.BRICK);
            for(let h=1;h<=WALL_H;h++)blocks.push([bx,baseY+h,bz,wt]);
            break;}
          case 'interior_wall':case 'partition':case 'drywall':{
            blocks.push([bx,baseY,bz,Ty.CONCRETE]);
            const wt2=resolveMat(mat,'wall',mats)||Ty.DRYWALL;
            for(let h=1;h<=WALL_H;h++)blocks.push([bx,baseY+h,bz,wt2]);
            break;}
          case 'floor':{
            blocks.push([bx,baseY,bz,Ty.CONCRETE]);
            const fm=resolveMat(mat,'floor',mats);
            if(fm&&fm!==Ty.CONCRETE)blocks.push([bx,baseY+0.1,bz,fm]);
            break;}
          case 'carpet':{blocks.push([bx,baseY,bz,Ty.CONCRETE]);blocks.push([bx,baseY+0.1,bz,Ty.CARPET]);break;}
          case 'tile':{blocks.push([bx,baseY,bz,Ty.CONCRETE]);blocks.push([bx,baseY+0.1,bz,Ty.TILE]);break;}
          case 'door':case 'entrance':case 'exit':{
            blocks.push([bx,baseY,bz,Ty.CONCRETE]);
            blocks.push([bx,baseY+0.08,bz,Ty.THRESHD]);
            blocks.push([bx,baseY+1,bz,Ty.DOORFRM]);
            const dp=resolveMat(mat,'door',mats);
            blocks.push([bx,baseY+2,bz,(dp===Ty.METAL)?Ty.METAL:Ty.DOORPNL]);
            blocks.push([bx,baseY+WALL_H,bz,isPerimeter?Ty.CONCRETE:Ty.DOORFRM]);
            if(cell==='entrance'||cell==='exit'){
              if(row===0)blocks.push([bx,baseY+0.08,bz-1,Ty.THRESHD]);
              else if(row===numRows-1)blocks.push([bx,baseY+0.08,bz+1,Ty.THRESHD]);
              else if(col===0)blocks.push([bx-1,baseY+0.08,bz,Ty.THRESHD]);
              else if(col===numCols-1)blocks.push([bx+1,baseY+0.08,bz,Ty.THRESHD]);
            }
            break;}
          case 'fire_door':{
            blocks.push([bx,baseY,bz,Ty.CONCRETE]);blocks.push([bx,baseY+0.08,bz,Ty.THRESHD]);
            blocks.push([bx,baseY+1,bz,Ty.METAL]);blocks.push([bx,baseY+2,bz,Ty.METAL]);
            blocks.push([bx,baseY+WALL_H,bz,Ty.CONCRETE]);break;}
          case 'window':{
            blocks.push([bx,baseY,bz,Ty.CONCRETE]);
            blocks.push([bx,baseY+1,bz,wallMat]);blocks.push([bx,baseY+2,bz,Ty.GLASS]);
            if(WALL_H>=3)blocks.push([bx,baseY+3,bz,wallMat]);
            break;}
          case 'stair':case 'stairs':case 'stairwell':case 'landing':{
            // Floor slab only on ground floor; upper floors are open stairwell shaft
            if(fi===0) blocks.push([bx,baseY,bz,Ty.CONCRETE]);
            break;}
          case 'column':case 'pillar':{
            blocks.push([bx,baseY,bz,Ty.CONCRETE]);
            const cm=resolveMat(mat,null,null)||Ty.CONCRETE;
            for(let h=1;h<=WALL_H;h++)blocks.push([bx,baseY+h,bz,cm]);break;}
          case 'elevator':case 'shaft':{
            blocks.push([bx,baseY,bz,Ty.METAL]);
            for(let h=1;h<=WALL_H;h++)blocks.push([bx,baseY+h,bz,Ty.METAL]);break;}
          default:blocks.push([bx,baseY,bz,Ty.CONCRETE]);break;
        }
      }
    }
    // ---- Identify stair cells before ceiling pass ----
    const isStairCell=Array.from({length:numRows},()=>new Uint8Array(numCols));
    for(let r=0;r<numRows;r++)for(let c2=0;c2<numCols;c2++){
      const ct=grid[r][c2].split(':')[0].trim().toLowerCase();
      if(ct==='stair'||ct==='stairs'||ct==='stairwell'||ct==='landing') isStairCell[r][c2]=1;
    }

    // Ceiling slab — skip stair cells to create floor opening for stair shaft
    const ceilMat=resolveMat(null,'ceiling',mats)||Ty.CONCRETE;
    const ceilY=baseY+WALL_H+1;
    for(let row=0;row<numRows;row++){for(let col=0;col<numCols;col++){
      if(isStairCell[row][col]) continue; // no ceiling over stairs — open shaft
      blocks.push([ox+col,ceilY,oz+row,ceilMat===Ty.WOOD?Ty.WOOD:Ty.CONCRETE]);
      const c=grid[row][col].split(':')[0].trim().toLowerCase();
      if(c==='floor'||c==='carpet'||c==='tile')blocks.push([ox+col,ceilY-1,oz+row,Ty.PLASTER]);
    }}

    // ---- STAIR POST-PASS: one STAIRWL block per cell, progressive Y ----
    const isStair=Array.from({length:numRows},()=>new Uint8Array(numCols));
    for(let r=0;r<numRows;r++)for(let c2=0;c2<numCols;c2++){
      const ct=grid[r][c2].split(':')[0].trim().toLowerCase();
      if(ct==='stair'||ct==='stairs'||ct==='stairwell'||ct==='landing') isStair[r][c2]=1;
    }
    // Flood-fill connected regions
    const visited=Array.from({length:numRows},()=>new Uint8Array(numCols));
    const regions=[];
    for(let r=0;r<numRows;r++)for(let c2=0;c2<numCols;c2++){
      if(isStair[r][c2]&&!visited[r][c2]){
        const cells=[];const queue=[[r,c2]];visited[r][c2]=1;
        while(queue.length){
          const[cr,cc]=queue.shift();cells.push([cr,cc]);
          for(const[dr,dc]of[[0,1],[0,-1],[1,0],[-1,0]]){
            const nr=cr+dr,nc=cc+dc;
            if(nr>=0&&nr<numRows&&nc>=0&&nc<numCols&&isStair[nr][nc]&&!visited[nr][nc]){
              visited[nr][nc]=1;queue.push([nr,nc]);
            }
          }
        }
        regions.push(cells);
      }
    }
    // Place one STAIRWL block per cell at progressive Y heights
    for(const region of regions){
      let minR=Infinity,maxR=-Infinity,minC=Infinity,maxC=-Infinity;
      for(const[r,c2]of region){minR=Math.min(minR,r);maxR=Math.max(maxR,r);minC=Math.min(minC,c2);maxC=Math.max(maxC,c2);}
      const spanR=maxR-minR+1,spanC=maxC-minC+1;
      const runAlongZ=spanR>=spanC;
      const runLen=runAlongZ?spanR:spanC;
      const totalRise=WALL_H+1; // full floor-to-floor rise
      const cellRise=totalRise/runLen; // each cell rises this much
      for(const[r,c2]of region){
        const bx=ox+c2,bz=oz+r;
        const stepIdx=runAlongZ?(r-minR):(c2-minC);
        const cellY=baseY+stepIdx*cellRise;
        blocks.push([bx,cellY,bz,Ty.STAIRWL,{rise:cellRise,dir:runAlongZ?0:1}]);
      }
    }
  }

  if(b.furniture_notes){
    const g0=floorGrids[0];const{cols:c0,numRows:r0}=g0?gridDims(g0):{cols:16,numRows:12};
    const ox0=-Math.floor(c0/2),oz0=-Math.floor(r0/2);const WALL_H=3;
    const items=flattenFloorMap(b.furniture_notes);
    for(const item of items){
      const c=parseCoord(item.coord);const fi=c.f||item.floorIdx;
      const baseY=fi*(WALL_H+1);const bx=ox0+c.x,bz=oz0+c.z;
      const lbl=item.label.toLowerCase();
      let ft=Ty.WOOD;
      if(lbl.includes('sofa')||lbl.includes('bed')||lbl.includes('couch')||lbl.includes('chair')||lbl.includes('mattress'))ft=Ty.FABRIC;
      else if(lbl.includes('toilet')||lbl.includes('shower')||lbl.includes('bath')||lbl.includes('sink'))ft=Ty.TILE;
      else if(lbl.includes('appliance')||lbl.includes('fridge')||lbl.includes('oven')||lbl.includes('washer'))ft=Ty.METAL;
      blocks.push([bx,baseY+1,bz,ft]);
      if(lbl.includes('bed')||lbl.includes('counter')||lbl.includes('sofa')||lbl.includes('couch')||lbl.includes('table')||lbl.includes('island')||lbl.includes('bath')||lbl.includes('shower'))
        blocks.push([bx+1,baseY+1,bz,ft]);
      if(lbl.includes('king')||lbl.includes('dining table')||lbl.includes('sectional')){blocks.push([bx,baseY+1,bz+1,ft]);blocks.push([bx+1,baseY+1,bz+1,ft]);}
    }
  }
  return blocks;
}

