<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Block Builder — Realistic</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600;700&family=Outfit:wght@300;500;700&display=swap');
*{margin:0;padding:0;box-sizing:border-box}
body{overflow:hidden;background:#0a0a0f;font-family:'Outfit',sans-serif}
canvas{display:block}
#ui{position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:10}

/* --- TOOLBAR (bottom center, collapsible) --- */
.toolbar{position:relative;display:flex;gap:3px;padding:7px 10px;background:rgba(10,10,18,.9);backdrop-filter:blur(20px);border:1px solid rgba(255,255,255,.08);border-radius:14px;box-shadow:0 8px 32px rgba(0,0,0,.5);flex-wrap:wrap;max-width:92vw;justify-content:center;transition:all .3s ease;transform-origin:bottom center}
.toolbar.hidden{transform:scaleY(0);opacity:0;pointer-events:none;max-height:0;padding:0 10px;margin:0;border-color:transparent}
.block-btn{width:44px;height:44px;border:2px solid transparent;border-radius:8px;cursor:pointer;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:1px;transition:all .2s;background:rgba(255,255,255,.04);color:rgba(255,255,255,.45);font-family:'JetBrains Mono',monospace;font-size:6.5px;letter-spacing:.4px}
.block-btn:hover{background:rgba(255,255,255,.1);color:#fff;transform:translateY(-2px)}
.block-btn.active{border-color:var(--accent);color:#fff;background:rgba(255,255,255,.08);box-shadow:0 0 14px var(--glow)}
.block-btn .swatch{width:18px;height:18px;border-radius:4px;box-shadow:inset 0 -2px 3px rgba(0,0,0,.3)}
.block-btn.fire-btn .swatch{background:linear-gradient(135deg,#ff4400,#ffaa00,#ff6600)!important;animation:fp .6s ease-in-out infinite alternate}
@keyframes fp{from{box-shadow:0 0 6px #ff4400}to{box-shadow:0 0 14px #ff8800}}

/* --- RIGHT CONTROL PANEL (tabbed) --- */
.ctrl-panel{position:absolute;top:60px;right:12px;width:168px;background:rgba(10,10,18,.92);backdrop-filter:blur(20px);border:1px solid rgba(255,255,255,.08);border-radius:14px;box-shadow:0 8px 32px rgba(0,0,0,.5);pointer-events:all;display:flex;flex-direction:column;overflow:hidden;max-height:calc(100vh - 130px);z-index:15}
.ctrl-tabs{display:flex;border-bottom:1px solid rgba(255,255,255,.06);flex-shrink:0}
.ctrl-tab{flex:1;padding:8px 0;border:none;background:transparent;color:rgba(255,255,255,.3);cursor:pointer;font-family:'JetBrains Mono',monospace;font-size:8px;letter-spacing:.6px;text-transform:uppercase;transition:all .2s;position:relative}
.ctrl-tab:hover{color:rgba(255,255,255,.6);background:rgba(255,255,255,.03)}
.ctrl-tab.active{color:var(--accent)}
.ctrl-tab.active::after{content:'';position:absolute;bottom:-1px;left:15%;right:15%;height:2px;background:var(--accent);border-radius:1px}
.ctrl-body{flex:1;overflow-y:auto;scrollbar-width:thin;scrollbar-color:rgba(255,255,255,.08) transparent}
.ctrl-section{display:none;padding:10px}
.ctrl-section.active{display:block}
.ctrl-section .sec-label{font-family:'JetBrains Mono',monospace;font-size:7.5px;color:rgba(255,255,255,.2);letter-spacing:1.2px;text-transform:uppercase;margin:8px 0 5px;padding:0}
.ctrl-section .sec-label:first-child{margin-top:0}

/* Buttons in control panel */
.cp-btn{width:100%;padding:8px 10px;border-radius:8px;border:1px solid rgba(255,255,255,.06);background:rgba(255,255,255,.03);color:rgba(255,255,255,.5);cursor:pointer;font-family:'JetBrains Mono',monospace;font-size:9px;transition:all .2s;text-align:left;display:flex;align-items:center;gap:8px;margin-bottom:4px}
.cp-btn:hover{color:#fff;background:rgba(255,255,255,.07);border-color:rgba(255,255,255,.12);transform:translateX(-2px)}
.cp-btn .cp-icon{font-size:14px;width:20px;text-align:center;flex-shrink:0}
.cp-btn .cp-info{display:flex;flex-direction:column}
.cp-btn .cp-name{font-size:9px;font-weight:600;font-family:'Outfit',sans-serif}
.cp-btn .cp-desc{font-size:7px;color:rgba(255,255,255,.2)}
.cp-btn.danger{border-color:rgba(255,70,70,.15);color:rgba(255,100,100,.5)}
.cp-btn.danger:hover{color:#ff6666;border-color:rgba(255,70,70,.4);background:rgba(50,10,10,.4)}
.cp-btn.import{border-color:rgba(100,180,255,.12);color:rgba(140,200,255,.5)}
.cp-btn.import:hover{color:#8cf;border-color:rgba(100,180,255,.3);background:rgba(10,15,30,.5)}

/* Mode buttons (Place/Erase) */
.mode-row{display:flex;gap:3px;margin-bottom:6px}
.mode-btn2{flex:1;padding:7px 0;border-radius:6px;border:1px solid rgba(255,255,255,.08);background:rgba(255,255,255,.03);color:rgba(255,255,255,.35);cursor:pointer;font-family:'JetBrains Mono',monospace;font-size:9px;text-align:center;transition:all .15s;letter-spacing:.5px}
.mode-btn2:hover{color:rgba(255,255,255,.7);background:rgba(255,255,255,.06)}
.mode-btn2.active{color:#fff;border-color:var(--accent);background:rgba(91,240,165,.08)}

/* View mode buttons */
.vm-btn{width:100%;padding:6px 10px;border-radius:6px;border:1px solid rgba(255,255,255,.05);background:transparent;color:rgba(255,255,255,.4);cursor:pointer;font-family:'JetBrains Mono',monospace;font-size:9px;text-align:left;transition:all .15s;margin-bottom:2px;display:flex;align-items:center;gap:6px}
.vm-btn:hover{color:rgba(255,255,255,.7);background:rgba(255,255,255,.04)}
.vm-btn.active{color:var(--accent);border-color:rgba(91,240,165,.2);background:rgba(91,240,165,.05)}
.vm-btn .vdot{width:6px;height:6px;border-radius:50%;flex-shrink:0}

/* Camera controls */
.cam-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:3px;margin:4px 0}
.cam-btn{height:28px;border-radius:6px;border:1px solid rgba(255,255,255,.06);background:rgba(255,255,255,.03);color:rgba(255,255,255,.35);cursor:pointer;font-family:'JetBrains Mono',monospace;font-size:10px;transition:all .15s;display:flex;align-items:center;justify-content:center;padding:0}
.cam-btn:hover{color:#fff;background:rgba(255,255,255,.08);border-color:rgba(255,255,255,.15)}
.cam-btn:active{transform:scale(.93)}
.cam-btn.accent{border-color:rgba(91,240,165,.15);color:rgba(91,240,165,.5)}
.cam-btn.accent:hover{color:var(--accent);border-color:var(--accent);background:rgba(91,240,165,.06)}
.cam-info{font-family:'JetBrains Mono',monospace;font-size:8px;color:rgba(255,255,255,.15);text-align:center;margin-top:3px}

/* Preset angle buttons */
.angle-row{display:flex;gap:2px;margin:4px 0}
.angle-btn{flex:1;padding:5px 0;border-radius:5px;border:1px solid rgba(255,255,255,.05);background:transparent;color:rgba(255,255,255,.3);cursor:pointer;font-family:'JetBrains Mono',monospace;font-size:7px;text-align:center;transition:all .15s}
.angle-btn:hover{color:rgba(255,255,255,.7);background:rgba(255,255,255,.05)}

/* Layer list */
.layer-scroll{overflow-y:auto;display:flex;flex-direction:column;gap:2px;max-height:180px;scrollbar-width:thin;scrollbar-color:rgba(255,255,255,.08) transparent}
/* Layer navigation */
.ly-nav{display:flex;align-items:center;gap:4px;margin-bottom:6px}
.ly-nav-btn{width:32px;height:32px;border-radius:6px;border:1px solid rgba(255,255,255,.08);background:rgba(255,255,255,.04);color:rgba(255,255,255,.4);cursor:pointer;font-size:12px;display:flex;align-items:center;justify-content:center;transition:all .15s}
.ly-nav-btn:hover{color:#fff;background:rgba(255,255,255,.1);border-color:rgba(255,255,255,.2)}
.ly-nav-btn:active{transform:scale(.9)}
.ly-nav-display{flex:1;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);border-radius:8px;padding:6px 10px;display:flex;justify-content:space-between;align-items:center}
.ly-nav-y{font-family:'JetBrains Mono',monospace;font-size:16px;font-weight:700;color:var(--accent)}
.ly-nav-m{font-family:'JetBrains Mono',monospace;font-size:9px;color:rgba(255,255,255,.25)}
/* Slider */
.ly-slider-wrap{margin:0 0 6px;padding:0 2px}
.ly-slider{-webkit-appearance:none;width:100%;height:6px;background:rgba(255,255,255,.06);border-radius:3px;outline:none;cursor:pointer}
.ly-slider::-webkit-slider-thumb{-webkit-appearance:none;width:14px;height:14px;border-radius:50%;background:var(--accent);border:2px solid rgba(10,10,18,.9);cursor:pointer;box-shadow:0 0 6px var(--glow)}
.ly-slider::-moz-range-thumb{width:14px;height:14px;border-radius:50%;background:var(--accent);border:2px solid rgba(10,10,18,.9);cursor:pointer}
/* Floor shortcuts */
.ly-floors{display:flex;flex-wrap:wrap;gap:3px;margin-bottom:4px}
.ly-floor-btn{padding:4px 8px;border-radius:5px;border:1px solid rgba(255,255,255,.06);background:rgba(255,255,255,.03);color:rgba(255,255,255,.3);cursor:pointer;font-family:'JetBrains Mono',monospace;font-size:8px;transition:all .12s;white-space:nowrap}
.ly-floor-btn:hover{color:rgba(255,255,255,.7);background:rgba(255,255,255,.06);border-color:rgba(255,255,255,.12)}
.ly-floor-btn.active{color:var(--accent);border-color:rgba(91,240,165,.2);background:rgba(91,240,165,.05)}
/* Isolate */
.ly-iso-row{display:flex;gap:3px;margin-bottom:4px}
.ly-iso-btn{flex:1;padding:5px 0;border-radius:5px;border:1px solid rgba(255,255,255,.06);background:rgba(255,255,255,.03);color:rgba(255,255,255,.3);cursor:pointer;font-family:'JetBrains Mono',monospace;font-size:8px;text-align:center;transition:all .12s}
.ly-iso-btn:hover{color:rgba(255,255,255,.7);background:rgba(255,255,255,.06)}
.ly-iso-btn.active{color:#ff8844;border-color:rgba(255,136,68,.3);background:rgba(255,136,68,.06)}
.ly-iso-btn.accent{border-color:rgba(91,240,165,.12);color:rgba(91,240,165,.4)}
.ly-iso-btn.accent:hover{color:var(--accent);border-color:var(--accent)}
/* Layer rows - enhanced */
.layer-row .ly-bar-wrap{width:40px;height:4px;background:rgba(255,255,255,.05);border-radius:2px;overflow:hidden;flex-shrink:0}
.layer-row .ly-bar{height:100%;background:var(--accent);border-radius:2px;transition:width .2s}
.layer-row{display:flex;align-items:center;gap:3px;padding:4px 6px;border-radius:5px;background:rgba(255,255,255,.02);border:1px solid rgba(255,255,255,.04);font-family:'JetBrains Mono',monospace;font-size:8px;color:rgba(255,255,255,.35);transition:all .12s}
.layer-row:hover{background:rgba(255,255,255,.05);color:rgba(255,255,255,.65)}
.layer-row.active{border-color:var(--accent);color:var(--accent);background:rgba(91,240,165,.04)}
.layer-row .ly-info{flex:1;cursor:pointer;display:flex;justify-content:space-between;align-items:center}
.layer-row .ly-y{font-weight:600;min-width:20px}
.layer-row .ly-m{color:rgba(255,255,255,.18);font-size:7px}
.layer-row .ly-ct{color:rgba(255,255,255,.18);font-size:7px}
.layer-row .ly-del{width:16px;height:16px;border:none;border-radius:3px;background:rgba(255,60,60,.08);color:rgba(255,100,100,.4);cursor:pointer;font-size:9px;display:flex;align-items:center;justify-content:center;transition:all .12s;padding:0;font-family:'JetBrains Mono',monospace;line-height:1}
.layer-row .ly-del:hover{background:rgba(255,60,60,.25);color:#ff6666}

/* Stats in info tab */
.info-grid{display:grid;grid-template-columns:1fr 1fr;gap:4px;margin-bottom:8px}
.info-card{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.04);border-radius:6px;padding:6px 8px;text-align:center}
.info-card .iv{font-family:'JetBrains Mono',monospace;font-size:13px;font-weight:600;color:rgba(255,255,255,.65)}
.info-card .il{font-family:'JetBrains Mono',monospace;font-size:7px;color:rgba(255,255,255,.2);letter-spacing:.5px;text-transform:uppercase;margin-top:2px}
.info-card.fire .iv{color:#ff8844}
.info-card.warn .iv{color:#ff5555}
.info-row{font-family:'JetBrains Mono',monospace;font-size:8px;color:rgba(255,255,255,.25);padding:2px 0;display:flex;justify-content:space-between}
.info-row span{color:rgba(255,255,255,.5)}
.info-row .acc{color:var(--accent)}

/* --- TOP BAR --- */
.dim-toggle{position:absolute;top:14px;left:50%;transform:translateX(-50%);display:flex;gap:0;pointer-events:all;background:rgba(10,10,18,.92);border-radius:10px;overflow:hidden;border:1px solid rgba(255,255,255,.1);box-shadow:0 4px 20px rgba(0,0,0,.5);z-index:20}
.dim-btn{padding:9px 22px;border:none;background:transparent;color:rgba(255,255,255,.35);cursor:pointer;font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:.8px;transition:all .25s;font-weight:600;position:relative}
.dim-btn:hover{color:rgba(255,255,255,.7);background:rgba(255,255,255,.04)}
.dim-btn.active{color:#fff;background:rgba(91,240,165,.12)}
.dim-btn.active::after{content:'';position:absolute;bottom:0;left:20%;right:20%;height:2px;background:var(--accent);border-radius:1px}
.plan-info{position:absolute;top:46px;left:50%;transform:translateX(-50%);font-family:'JetBrains Mono',monospace;font-size:9px;color:rgba(255,255,255,.2);pointer-events:none;white-space:nowrap;display:none;letter-spacing:.4px;z-index:15}
.plan-info.active{display:block}

/* --- TITLE + STATS (top-left compact) --- */
.top-left{position:absolute;top:14px;left:14px;pointer-events:none;z-index:15}
.top-left h1{font-family:'Outfit',sans-serif;font-weight:700;font-size:14px;color:rgba(255,255,255,.8);letter-spacing:-.5px;margin-bottom:1px}
.top-left .subtitle{font-family:'JetBrains Mono',monospace;font-size:8px;color:rgba(255,255,255,.15);letter-spacing:.8px;text-transform:uppercase}

/* --- HINT BAR --- */
.hint{position:absolute;bottom:76px;left:50%;transform:translateX(-50%);font-family:'JetBrains Mono',monospace;font-size:8px;color:rgba(255,255,255,.12);pointer-events:none;letter-spacing:.4px;white-space:nowrap;z-index:15}

/* --- MODAL --- */
.modal-overlay{position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.7);backdrop-filter:blur(8px);display:none;align-items:center;justify-content:center;z-index:100;pointer-events:all}
.modal-overlay.open{display:flex}
.modal{background:rgba(14,14,24,.97);border:1px solid rgba(255,255,255,.1);border-radius:16px;padding:24px;width:min(680px,90vw);max-height:85vh;display:flex;flex-direction:column;box-shadow:0 20px 60px rgba(0,0,0,.6)}
.modal h2{font-family:'Outfit',sans-serif;font-weight:700;font-size:16px;color:rgba(255,255,255,.85);margin-bottom:4px}
.modal .sub{font-family:'JetBrains Mono',monospace;font-size:9px;color:rgba(255,255,255,.25);margin-bottom:14px;letter-spacing:.5px}
.modal textarea{width:100%;height:260px;background:rgba(0,0,0,.4);border:1px solid rgba(255,255,255,.1);border-radius:10px;color:rgba(255,255,255,.8);font-family:'JetBrains Mono',monospace;font-size:10px;padding:12px;resize:vertical;line-height:1.5;outline:none}
.modal textarea:focus{border-color:rgba(91,240,165,.3)}
.modal textarea::placeholder{color:rgba(255,255,255,.15)}
.modal-actions{display:flex;gap:8px;margin-top:14px;justify-content:flex-end;align-items:center}
.modal-actions .info{font-family:'JetBrains Mono',monospace;font-size:9px;color:rgba(255,255,255,.2);margin-right:auto}
.modal-btn{padding:10px 20px;border-radius:8px;border:1px solid rgba(255,255,255,.1);background:rgba(255,255,255,.06);color:rgba(255,255,255,.6);cursor:pointer;font-family:'JetBrains Mono',monospace;font-size:11px;transition:all .2s}
.modal-btn:hover{color:#fff;border-color:rgba(255,255,255,.25)}
.modal-btn.primary{border-color:var(--accent);color:var(--accent);background:rgba(91,240,165,.08)}
.modal-btn.primary:hover{background:rgba(91,240,165,.15);color:#fff}
.modal-btn.sample{border-color:rgba(100,180,255,.3);color:rgba(140,200,255,.7)}
.modal-btn.sample:hover{color:#8cf;background:rgba(100,180,255,.1)}

/* --- 2D CANVAS --- */
#canvas2d{position:absolute;top:0;left:0;width:100%;height:100%;display:none;cursor:crosshair;z-index:5;pointer-events:none}
#canvas2d.active{display:block;pointer-events:all}

:root{--accent:#5bf0a5;--glow:rgba(91,240,165,.25)}
</style>
</head>
<body>
<div id="ui">
  <canvas id="canvas2d"></canvas>

  <!-- TOP: 3D/2D toggle -->
  <div class="dim-toggle">
    <button class="dim-btn active" data-dim="3d" onclick="setDim('3d')">3D</button>
    <button class="dim-btn" data-dim="2d" onclick="setDim('2d')">2D PLAN</button>
  </div>
  <div class="plan-info" id="planInfo">Layer Y<span id="pi-y">0</span> · <span id="pi-m">0.00m</span> · LMB paint · RMB erase · MMB pan · Ctrl+click pick · [/] layers · X mode</div>

  <!-- TOP-LEFT: Title -->
  <div class="top-left"><h1>Block Builder</h1><span class="subtitle">Fire &amp; Structure Sim</span></div>

  <!-- RIGHT: Tabbed Control Panel -->
  <div class="ctrl-panel" id="ctrlPanel">
    <div class="ctrl-tabs">
      <button class="ctrl-tab active" data-tab="build" onclick="setCtrlTab('build')">Build</button>
      <button class="ctrl-tab" data-tab="view" onclick="setCtrlTab('view')">View</button>
      <button class="ctrl-tab" data-tab="layers" onclick="setCtrlTab('layers')">Layers</button>
      <button class="ctrl-tab" data-tab="info" onclick="setCtrlTab('info')">Info</button>
    </div>
    <div class="ctrl-body">

      <!-- BUILD TAB -->
      <div class="ctrl-section active" data-tab="build">
        <div class="sec-label">Mode</div>
        <div class="mode-row">
          <button class="mode-btn2 active" data-mode="place" onclick="setMode('place')">PLACE</button>
          <button class="mode-btn2" data-mode="erase" onclick="setMode('erase')">ERASE</button>
          <button class="mode-btn2 active" id="physBtn" onclick="togglePhysics()" title="Pause/Play physics (P)" style="flex:.8">⏸ Pause</button>
        </div>
        <div class="sec-label">Presets</div>
        <button class="cp-btn" onclick="spawnPreset('apartment')"><span class="cp-icon">🏢</span><span class="cp-info"><span class="cp-name">Apartment</span><span class="cp-desc">5-floor · stairwell</span></span></button>
        <button class="cp-btn" onclick="spawnPreset('school')"><span class="cp-icon">🏫</span><span class="cp-info"><span class="cp-name">School</span><span class="cp-desc">2-floor · classrooms</span></span></button>
        <button class="cp-btn" onclick="spawnPreset('gasstation')"><span class="cp-icon">⛽</span><span class="cp-info"><span class="cp-name">Gas Station</span><span class="cp-desc">canopy · fuel tanks</span></span></button>
        <button class="cp-btn" onclick="spawnPreset('house')"><span class="cp-icon">🏠</span><span class="cp-info"><span class="cp-name">Family Home</span><span class="cp-desc">2-floor · 4 bed · garage</span></span></button>
        <button class="cp-btn" onclick="spawnPreset('stairdemo')"><span class="cp-icon">🪜</span><span class="cp-info"><span class="cp-name">Stair Tower</span><span class="cp-desc">3-floor · stair types</span></span></button>
        <div class="sec-label">Floorplan</div>
        <button class="cp-btn import" onclick="openImport()"><span class="cp-icon">📐</span><span class="cp-info"><span class="cp-name">Import JSON</span><span class="cp-desc">paste floorplan data</span></span></button>
        <div style="height:6px"></div>
        <button class="cp-btn danger" onclick="clearAll()"><span class="cp-icon" style="font-size:11px">✕</span><span class="cp-name">Clear all</span></button>
      </div>

      <!-- VIEW TAB -->
      <div class="ctrl-section" data-tab="view">
        <div class="sec-label">Render Mode</div>
        <button class="vm-btn active" data-vm="standard" onclick="setView('standard')"><span class="vdot" style="background:#aab"></span>Standard</button>
        <button class="vm-btn" data-vm="wireframe" onclick="setView('wireframe')"><span class="vdot" style="background:#6cf"></span>Wireframe</button>
        <button class="vm-btn" data-vm="xray" onclick="setView('xray')"><span class="vdot" style="background:#8ef"></span>X-Ray</button>
        <button class="vm-btn" data-vm="blueprint" onclick="setView('blueprint')"><span class="vdot" style="background:#46a"></span>Blueprint</button>
        <button class="vm-btn" data-vm="thermal" onclick="setView('thermal')"><span class="vdot" style="background:#f72"></span>Thermal</button>
        <div class="sec-label">Camera</div>
        <div class="cam-grid">
          <button class="cam-btn" onclick="camOrbit(-.3,0)" title="Rotate left">◀</button>
          <button class="cam-btn" onclick="camPan(0,-1)" title="Pan forward">▲</button>
          <button class="cam-btn" onclick="camOrbit(.3,0)" title="Rotate right">▶</button>
          <button class="cam-btn" onclick="camPan(-1,0)" title="Pan left">◁</button>
          <button class="cam-btn" onclick="camPan(0,1)" title="Pan back">▼</button>
          <button class="cam-btn" onclick="camPan(1,0)" title="Pan right">▷</button>
          <button class="cam-btn" onclick="camOrbit(0,.15)" title="Tilt up">↑</button>
          <button class="cam-btn accent" onclick="camReset()" title="Reset camera">R</button>
          <button class="cam-btn" onclick="camOrbit(0,-.15)" title="Tilt down">↓</button>
          <button class="cam-btn" onclick="camZoom(-3)" title="Zoom in">+</button>
          <button class="cam-btn accent" onclick="camFocus()" title="Focus on building">F</button>
          <button class="cam-btn" onclick="camZoom(3)" title="Zoom out">−</button>
        </div>
        <div class="sec-label">Preset Angles</div>
        <div class="angle-row">
